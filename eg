        MainButton.BorderSizePixel = 0
        MainButton.Position = UDim2.new(1, -5, 0.5, 0)
        MainButton.Size = UDim2.new(0, 13, 0, 13)
        MainButton.ZIndex = Zindex + 5
        MainButton.Image = NoirUI:_GetIcon("chevron-down")

        NoirUI:_Hover(ValueItems, function()
            NoirUI:_Animation(ValueItems, TweenInfo.new(0.3), { BackgroundColor3 = NoirUI.Colors.MouseEnter });
        end, function()
            NoirUI:_Animation(ValueItems, TweenInfo.new(0.3), { BackgroundColor3 = NoirUI.Colors.DropColor });
        end);

        local repi;
        local Button = NoirUI:_Input(ValueItems);

        repi = NoirUI:_LoadDropdown(Button, function(value)
            Config.Default = value;

            repi:SetData(Config.Default, Config.Values, Config.Multi, false);
            repi:SetDefault(Config.Default);

            ValueText.Text = DaTabarser(Config.Default);

            Config.Callback(Config.Default);
        end);

        repi.EventOut:Connect(function(v)
            if v then
                NoirUI:_Animation(MainButton, TweenInfo.new(0.2), { Rotation = -180 })
            else
                NoirUI:_Animation(MainButton, TweenInfo.new(0.2), { Rotation = 0 })
            end;
        end)

        repi:SetData(Config.Default, Config.Values, Config.Multi, false);
        repi:Refersh();

        local Args = {};

        Args.Flag = Config.Flag;

        function Args:SetValue(Value)
            Config.Default = Value;

            ValueText.Text = DaTabarser(Config.Default);

            repi:SetData(Config.Default, Config.Values, Config.Multi, true);

            Config.Callback(Value);
        end;

        function Args:SetText(str)
            BlockText.Text = str or Config.Name
        end;

        function Args:GetText()
            return BlockText.Text;
        end;

        function Args:SetValues(v)
            Config.Values = v;

            repi:SetData(Config.Default, Config.Values, Config.Multi, true);
        end;

        Args.Signal = Signal:Connect(function(bool)
            if bool then
                NoirUI:_Animation(BlockText, TweenInfo.new(0.2), { TextTransparency = 0.100 });
                NoirUI:_Animation(BlockLine, TweenInfo.new(0.2), { BackgroundTransparency = 0.100 });
                NoirUI:_Animation(ValueItems, TweenInfo.new(0.2), { BackgroundTransparency = 0 });
                NoirUI:_Animation(UIStroke, TweenInfo.new(0.2), { Transparency = 0 });
                NoirUI:_Animation(ValueText, TweenInfo.new(0.32), { TextTransparency = 0 });
                NoirUI:_Animation(MainButton, TweenInfo.new(0.2), { ImageTransparency = 0 });
            else
                NoirUI:_Animation(BlockText, TweenInfo.new(0.2), { TextTransparency = 1 });
                NoirUI:_Animation(BlockLine, TweenInfo.new(0.2), { BackgroundTransparency = 1 });
                NoirUI:_Animation(ValueItems, TweenInfo.new(0.2), { BackgroundTransparency = 1 });
                NoirUI:_Animation(UIStroke, TweenInfo.new(0.2), { Transparency = 1 });
                NoirUI:_Animation(ValueText, TweenInfo.new(0.2), { TextTransparency = 1 });
                NoirUI:_Animation(MainButton, TweenInfo.new(0.2), { ImageTransparency = 1 });
            end;
        end);

        Args.Link = NoirUI:_LoadOption({
            AddLink = function(self, Name, Default)
                return NoirUI:_AddLinkValue(Name, Default, LinkValues, LinkValues, {
                    Tween = TweenInfo.new(0.2)
                }, Signal);
            end,
            Root = Dropdown
        });

        function Args:GetValue()
            return Config.Default;
        end;

        if Config.Flag then
            NoirUI.Flags[Config.Flag] = Args;
        end;

        return Args;
    end;

    return Args;
end;

