function NoirUI:RollingEffect(parent)
    local gradient = Instance.new("UIGradient")
    gradient.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0.00, 0.4),
        NumberSequenceKeypoint.new(1.00, 0.00)
    }
    gradient.Parent = parent
    return gradient
end

function NoirUI:CreateShadow(parent, rollingEffect)
    local Shadow = {}
    
    local strokes = {}
    local thicknesses = {6, 5, 4, 3}
    local gradients = {}
    
    for i, thick in ipairs(thicknesses) do
        local stroke = Instance.new("UIStroke")
        stroke.Thickness = thick
        stroke.Transparency = 1
        stroke.Color = Color3.fromRGB(0, 0, 0)
        stroke.Parent = parent
        table.insert(strokes, stroke)
        
        if rollingEffect then
            local grad = NoirUI:RollingEffect(stroke)
            table.insert(gradients, grad)
        end
    end
    
    local rollingThread
    
    Shadow.Render = function(value)
        if rollingThread then
            task.cancel(rollingThread)
            rollingThread = nil
        end
        
        if value then
            for _, stroke in ipairs(strokes) do
                TweenService:Create(stroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                    Transparency = 0.9
                }):Play()
            end
            
            if rollingEffect and #gradients > 0 then
                rollingThread = task.spawn(function()
                    while true do
                        task.wait(0.025)
                        for _, grad in ipairs(gradients) do
                            grad.Rotation = (grad.Rotation or 0) + 20
                        end
                    end
                end)
            end
        else
            for _, stroke in ipairs(strokes) do
                TweenService:Create(stroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                    Transparency = 1
                }):Play()
            end
        end
    end
    
    return Shadow
end

