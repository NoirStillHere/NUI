function NoirUI:RefreshCurrentColor()
    for i, v in next, NoirUI.Elements.Highlight do
        if v.Element and v.Property then
            v.Element[v.Property] = NoirUI.Colors.Highlight;
        end;
    end;

    for i, v in next, NoirUI.Elements do
        if v.Element and v.Property and v.Element:GetAttribute('Enabled') then
            v.Element[v.Property] = NoirUI.Colors.Highlight;
        end;
    end;

    for i, v in next, NoirUI.Elements.Risky do
        if v.Element and v.Property then
            v.Element[v.Property] = NoirUI.Colors.Risky;
        end;
    end;

    for i, v in next, NoirUI.Elements.BlockColor do
        if v.Element and v.Property then
            v.Element[v.Property] = NoirUI.Colors.BlockColor;
        end;
    end;

    for i, v in next, NoirUI.Elements.BGDBColor do
        if v.Element and v.Property then
            v.Element[v.Property] = NoirUI.Colors.BGDBColor;
        end;
    end;

    for i, v in next, NoirUI.Elements.StrokeColor do
        if v.Element and v.Property then
            v.Element[v.Property] = NoirUI.Colors.StrokeColor;
        end;
    end;

    for i, v in next, NoirUI.Elements.SwitchColor do
        if v.Element and v.Property and v.Element[v.Property] ~= NoirUI.Colors.MouseEnter then
            v.Element[v.Property] = NoirUI.Colors.SwitchColor;
        end;
    end;

    for i, v in next, NoirUI.Elements.BlockBackground do
        if v.Element and v.Property and v.Element[v.Property] then
            v.Element[v.Property] = NoirUI.Colors.BlockBackground;
        end;
    end;

    for i, v in next, NoirUI.Elements.DropColor do
        if v.Element and v.Property then
            v.Element[v.Property] = NoirUI.Colors.DropColor;
        end;
    end;

    for i, v in next, NoirUI.Elements.LineColor do
        if v.Element and v.Property then
            v.Element[v.Property] = NoirUI.Colors.LineColor;
        end;
    end;

    for i, v in next, NoirUI.Elements.HighStrokeColor do
        if v.Element and v.Property then
            v.Element[v.Property] = NoirUI.Colors.HighStrokeColor;
        end;
    end;
end;

function NoirUI:ChangeHighlightColor(NewColor)
    local H, S, V = NewColor:ToHSV();

    NoirUI.Colors.Highlight = NewColor;
    NoirUI.Colors.Toggle = Color3.fromHSV(H, S, V - 0.2);

    for i, v in next, NoirUI.Elements.Highlight do
        if v.Element and v.Property then
            v.Element[v.Property] = NewColor;
        end;
    end;

    for i, v in next, NoirUI.Elements do
        if v.Element and v.Property and v.Element:GetAttribute('Enabled') then
            v.Element[v.Property] = NewColor;
        end;
    end;
end;

