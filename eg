        if bool then
            if not IsSame then
                DropdownWindow.Position = DropPosition;
            end;

            NoirUI:_Animation(DropdownWindow, TweenInfo.new(0.2), { BackgroundTransparency = 0, Position = MainPosition, Size = UDim2.new(0, BaseParent.AbsoluteSize.X - 1, 0, math.clamp(UIListLayout.AbsoluteContentSize.Y + 10, 10, 200)) })
