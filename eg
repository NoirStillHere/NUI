    -- Hàm cập nhật gradient
    function Window:UpdateGradient(colors, speed)
        if not colors or #colors < 2 then return end
        StrokeColors = colors
        
        -- Cập nhật tất cả stroke
        local strokes = {
            MainStroke, LoadingStroke, SideStroke, ContStroke, TS, ns
        }
        
        -- Tìm tất cả stroke trong UI
        local function findStrokes(parent)
            for _, child in pairs(parent:GetChildren()) do
                if child:IsA("UIStroke") then
                    table.insert(strokes, child)
                end
                findStrokes(child)
            end
        end
        
        findStrokes(Main)
        findStrokes(TBtn)
        
        for _, stroke in pairs(strokes) do
            if stroke then
                -- Xóa gradient cũ
                local oldGradient = stroke:FindFirstChild("UIGradient")
                if oldGradient then oldGradient:Destroy() end
                
                -- Áp dụng gradient mới
                ApplyGradientToStroke(stroke, colors, speed or 30)
            end
        end
        
        -- Cập nhật glow
        local glows = {}
        local function findGlows(parent)
            for _, child in pairs(parent:GetChildren()) do
                if child.Name == "GlowEffect" then 
                    table.insert(glows, child) 
                end
                findGlows(child)
            end
        end
        
        findGlows(Main)
        findGlows(TBtn)
        findGlows(LoadingFrame)
        
        for _, glow in pairs(glows) do
            local oldGradient = glow:FindFirstChild("UIGradient")
            if oldGradient then oldGradient:Destroy() end
            
            if #colors >= 2 then
                local gradient = Instance.new("UIGradient")
                local colorKeys = {}
                local step = 1 / (#colors - 1)
                for i, color in ipairs(colors) do
                    local position = (i - 1) * step
                    table.insert(colorKeys, ColorSequenceKeypoint.new(position, color))
                end
                gradient.Color = ColorSequence.new(colorKeys)
                gradient.Parent = glow
            else
                glow.ImageColor3 = colors[1] or ACCENT
            end
        end
        
        NoirUI:Notify("Gradient", "Đã cập nhật gradient!", "palette", "Success")
    end
    
    -- Hàm bật/tắt glow
    function Window:ToggleGlow(enabled)
        GlowEnabled = enabled
        
        local function updateGlowVisibility(parent)
            for _, child in pairs(parent:GetChildren()) do
                if child.Name == "GlowEffect" then
                    child.Visible = enabled
                end
                updateGlowVisibility(child)
            end
        end
        
        updateGlowVisibility(Main)
        updateGlowVisibility(TBtn)
        updateGlowVisibility(LoadingFrame)
        
        NoirUI:Notify("Glow", enabled and "Đã bật glow" or "Đã tắt glow", "sparkles", "Success")
    end
    
    -- Hàm set glow intensity
    function Window:SetGlowIntensity(intensity)
        GlowIntensity = math.clamp(intensity, 0, 1)
        
        local function updateGlowIntensity(parent)
            for _, child in pairs(parent:GetChildren()) do
