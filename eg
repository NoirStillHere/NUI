            local min = range[1]
            local max = range[2]
            local increment = opt.increment or 1
            local defaultValue = opt.Default or min
            defaultValue = math.floor((defaultValue - min) / increment) * increment + min
            defaultValue = math.clamp(defaultValue, min, max)
