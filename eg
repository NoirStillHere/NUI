function CK:Notify(title, message, iconName, soundType)
    if soundType then
        PlaySound(soundType)
    else
        PlaySound("Notification")
    end

    local ScreenGui = self.Root or game:GetService("CoreGui")
    local n = Instance.new("Frame")
    n.Size = UDim2.new(0, 280, 0, 65)
    n.Position = UDim2.new(1, 20, 0.8, 0)
    n.BackgroundColor3 = NoirColors.Surface
    n.BackgroundTransparency = 0.1
    n.Parent = ScreenGui
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 8)

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = NoirColors.Accent
    Stroke.Thickness = 1
    Stroke.Transparency = 0.5
    Stroke.Parent = n

    if iconName then
        local icon = Instance.new("ImageLabel")
        icon.Size = UDim2.new(0, 24, 0, 24)
        icon.Position = UDim2.new(0, 10, 0.5, -12)
        icon.BackgroundTransparency = 1
        icon.Image = LucideIcons[iconName] or iconName
        icon.ImageColor3 = NoirColors.Text
        icon.ZIndex = 2
        icon.Parent = n
    end

    local tl = Instance.new("TextLabel")
    tl.Size = UDim2.new(1, iconName and -45 or -15, 0, 20)
    tl.Position = UDim2.new(0, iconName and 40 or 15, 0, 5)
    tl.Text = title
    tl.TextColor3 = NoirColors.Accent
    tl.TextTransparency = 0
    tl.BackgroundTransparency = 1
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 13
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.Parent = n

    local ml = Instance.new("TextLabel")
    ml.Size = UDim2.new(1, iconName and -45 or -25, 0, 35)
    ml.Position = UDim2.new(0, iconName and 40 or 15, 0, 25)
    ml.Text = message
    ml.TextColor3 = NoirColors.Text
    ml.TextTransparency = 0.3
    ml.BackgroundTransparency = 1
    ml.TextWrapped = true
    ml.TextXAlignment = Enum.TextXAlignment.Left
    ml.TextYAlignment = Enum.TextYAlignment.Top
    ml.Font = Enum.Font.Gotham
    ml.TextSize = 11
    ml.Parent = n

    -- Animation
    TweenService:Create(n, TweenInfo.new(0.5, Enum.EasingStyle.Back), {
        Position = UDim2.new(1, -290, 0.8, 0)
    }):Play()

    task.delay(4, function()
        TweenService:Create(n, TweenInfo.new(0.5), {
            Position = UDim2.new(1, 20, n.Position.Y.Scale, n.Position.Y.Offset),
            BackgroundTransparency = 1
        }):Play()
        task.wait(0.5)
        n:Destroy()
    end)
end

