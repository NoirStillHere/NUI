            local function updateSlider(input)
                local p = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
                local rawValue = min + (max - min) * p
                local value = math.floor((rawValue - min) / increment) * increment + min
                value = math.clamp(value, min, max)
                local newPercent = (value - min) / (max - min)
                
                currentValue = value
                
                TweenService:Create(fill, TweenInfo.new(0.05), {
                    Size = UDim2.new(newPercent, 0, 1, 0)
                }):Play()
                TweenService:Create(handle, TweenInfo.new(0.05), {
                    Position = UDim2.new(newPercent, -6, 0.5, -6)
                }):Play()
                
                valueLabel.Text = tostring(value) .. (config.Suffix or "")
                if config.Callback then config.Callback(value) end
            end
            
            local isHeld = false
            sliderBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isHeld = true
                    updateSlider(input)
                end
            end)
            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isHeld = false
                end
            end)
            UIS.InputChanged:Connect(function(input)
                if isHeld and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    updateSlider(input)
                end
            end)
            
            if config.Flag then
                Tab:AddFlag(config.Flag, {
                    GetValue = function() return currentValue end,
                    SetValue = function(v) 
                        local newValue = math.floor((v - min) / increment) * increment + min
                        newValue = math.clamp(newValue, min, max)
                        currentValue = newValue
                        local newPercent = (currentValue - min) / (max - min)
                        TweenService:Create(fill, TweenInfo.new(0.3), {
                            Size = UDim2.new(newPercent, 0, 1, 0)
                        }):Play()
                        TweenService:Create(handle, TweenInfo.new(0.3), {
                            Position = UDim2.new(newPercent, -6, 0.5, -6)
                        }):Play()
                        valueLabel.Text = tostring(currentValue) .. (config.Suffix or "")
                        if config.Callback then config.Callback(currentValue) end
                    end
                })
            end
            
            return container
        end
        
