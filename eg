    -- ============================================
    -- HOVER TAB FRAME
    -- ============================================
    local OldDelayThread;
    local DurationTime = tick();

    NoirUI:_Hover(TabFrame, function()
        if OldDelayThread then
            task.cancel(OldDelayThread);
            OldDelayThread = nil;
        end;

        if WindowArgs.AlwayShowTab then
            return;
