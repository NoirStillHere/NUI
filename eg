            end
            TabContainer.Visible = true
            resetAllTabs()
            BT.TextColor3 = currentTheme.text or Color3.fromRGB(245,245,250)
            local tabImg = B:FindFirstChild("ImageLabel")
            if tabImg then tabImg.ImageColor3 = currentTheme.text or Color3.fromRGB(245,245,250) end
            updateCanvas()
        end
        
        B.MouseButton1Click:Connect(function()
            PlaySound("Tab")
            CreateClickScaleEffect(B)
            selectThisTab()
        end)
        
        table.insert(allTabButtons, B)
        
        if #TScroll:GetChildren() == 1 then
            selectThisTab()
        end
        
        -- Tab Object
        local Tab = { Count = 0, Elements = {}, Connections = {}, _currentSectionContent = nil, _sectionLayout = nil }
        local function GetO() Tab.Count = Tab.Count + 1; return Tab.Count end
        
        local function filterElements(searchText)
            local search = searchText:lower()
            for _, element in pairs(Tab.Elements) do
                if search == "" or (element.Name and element.Name:lower():find(search)) then
                    element.Visible = true
                else
                    element.Visible = false
                end
            end
            updateCanvas()
        end
        SearchBox.Changed:Connect(function(prop)
            if prop == "Text" then filterElements(SearchBox.Text) end
        end)
        
        -- Elements (giữ nguyên các hàm CreateLabel, CreateSection, CreateParagraph, CreateTextBox, CreateButton, CreateToggle, CreateSlider, CreateColorPicker, CreateDropdown, CreateRunBox từ code trước)
        -- ... (các hàm này giữ nguyên như bản đã sửa ở trên)
        
        Tab._button = B
        return Tab
    end
    
    task.wait()
    return Window
end

return NoirUI
