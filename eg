function NoirUI:_SetNilP(Ins, Parent)
    NoirUI.WindowsNil = NoirUI.WindowsNil or {};
    NoirUI.NilFolder = NoirUI.NilFolder or Instance.new('Folder');

    if not NoirUI.WindowsNil[Ins] then
        local win = NoirUI:_GetWindowFromElement(Ins);
        NoirUI.WindowsNil[Ins] = win;
    end;

    Ins.Parent = Parent or NoirUI.NilFolder;
end;

function NoirUI:SetAllText(flags)
    if not flags then
        for i, v in next, NoirUI.Flags do
            if v.SetText then
                v:SetText(nil);
            end;
        end;
        return;
    end;

    flags = flags or {};

    for i, v in next, flags do
        if NoirUI.Flags[i] and NoirUI.Flags[i].SetText then
            NoirUI.Flags[i]:SetText(v);
        end;
    end;
end;

