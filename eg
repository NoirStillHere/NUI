local function AddSearchBarToHeader()
    local MainFrame = Window.Root:FindFirstChildOfClass("Frame")
    if not MainFrame then return end

    -- Tìm header
    local Header = MainFrame:FindFirstChildWhichIsA("Frame")
    if not Header then return end

    -- Tạo search frame
    local SearchFrame = Instance.new("Frame")
    SearchFrame.Size = UDim2.new(0, 150, 0, 28)
    SearchFrame.Position = UDim2.new(1, -160, 0.5, -14)
    SearchFrame.BackgroundColor3 = NoirColors.Surface
    SearchFrame.BackgroundTransparency = 0.5
    SearchFrame.ZIndex = 10
    SearchFrame.Parent = Header
    Instance.new("UICorner", SearchFrame).CornerRadius = UDim.new(0, 6)
    
    local Stroke = Instance.new("UIStroke")
    Stroke.Color = NoirColors.Border
    Stroke.Thickness = 1
    Stroke.Transparency = 0.5
    Stroke.Parent = SearchFrame

    -- Icon search
    local SearchIcon = Instance.new("ImageLabel")
    SearchIcon.Size = UDim2.new(0, 16, 0, 16)
    SearchIcon.Position = UDim2.new(0, 8, 0.5, -8)
    SearchIcon.BackgroundTransparency = 1
    SearchIcon.Image = LucideIcons['search']
    SearchIcon.ImageColor3 = NoirColors.TextSecondary
    SearchIcon.Parent = SearchFrame

    -- Input
    local SearchBox = Instance.new("TextBox")
    SearchBox.Size = UDim2.new(1, -35, 1, 0)
    SearchBox.Position = UDim2.new(0, 30, 0, 0)
    SearchBox.BackgroundTransparency = 1
    SearchBox.PlaceholderText = "Search..."
    SearchBox.Text = ""
    SearchBox.TextColor3 = NoirColors.Text
    SearchBox.TextTransparency = 0
    SearchBox.Font = Enum.Font.Gotham
    SearchBox.TextSize = 12
    SearchBox.ClearTextOnFocus = false
    SearchBox.Parent = SearchFrame

    -- Hàm search
    local function SearchItems(query)
        query = query:lower()
        -- Tìm tất cả các label trong UI
        for _, item in pairs(Window.Root:GetDescendants()) do
            if item:IsA("TextLabel") or item:IsA("TextButton") then
                local text = item.Text or ""
                if query == "" or text:lower():find(query) then
                    item.Visible = true
                    -- Hiện cả parent
                    local parent = item.Parent
                    while parent and parent ~= Window.Root do
                        if parent:IsA("Frame") then
                            parent.Visible = true
                        end
                        parent = parent.Parent
                    end
                else
                    -- Ẩn nếu không khớp
                    local shouldHide = true
                    -- Kiểm tra xem có child nào khớp không
                    for _, child in pairs(item:GetDescendants()) do
                        if child:IsA("TextLabel") or child:IsA("TextButton") then
                            local childText = child.Text or ""
                            if childText:lower():find(query) then
                                shouldHide = false
                                break
                            end
                        end
                    end
                    if shouldHide then
                        item.Visible = false
                    end
                end
            end
        end
    end

    SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        SearchItems(SearchBox.Text)
    end)

    return SearchBox
end

