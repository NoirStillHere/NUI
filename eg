                end;

                for i, v in next, __signals do
                    v:Disconnect();
                end;

                for i, v in next, FullConfig do
                    local Button = TabArgs:_DrawConfig();

                    Button:SetInfo(v.Info.Author, v.Name);

                    table.insert(__signals, TabOpenSignal:Connect(function(v)
                        Button:Toggle(v);
