    -- Config Functions
    local function GetConfigData()
        local data = {}
        for flag, v in pairs(Window.Flags) do
            if v and v.GetValue then
                local val = v:GetValue()
                if typeof(val) == "Color3" then
                    data[flag] = {Type = "Color3", R = val.R, G = val.G, B = val.B}
                else
                    data[flag] = {Type = "Value", Value = val}
                end
            end
        end
        return data
    end
    
    local function LoadConfigData(data)
        for flag, v in pairs(data) do
            if Window.Flags[flag] and Window.Flags[flag].SetValue then
                if v.Type == "Color3" then
                    Window.Flags[flag]:SetValue(Color3.new(v.R, v.G, v.B))
                else
                    Window.Flags[flag]:SetValue(v.Value)
                end
            end
        end
    end
    
    local function SaveConfig(name)
        local data = GetConfigData()
        data.__INFO = {
            Name = name,
            Author = Players.LocalPlayer.DisplayName,
            Date = os.date("%Y-%m-%d %H:%M:%S")
        }
        local json = HttpService:JSONEncode(data)
        writefile(Window.ConfigFolder .. "/" .. name .. ".json", json)
        RefreshConfigList()
    end
    
    local function LoadConfig(name)
        local path = Window.ConfigFolder .. "/" .. name .. ".json"
        if isfile(path) then
            local json = readfile(path)
            local data = HttpService:JSONDecode(json)
            LoadConfigData(data)
            ConfigName.Text = name
            RefreshConfigList()
            NoirUI:Notify("📂 Config", "Loaded: " .. name, "folder", "Success")
        end
    end
    
    local function DeleteConfig(name)
        local path = Window.ConfigFolder .. "/" .. name .. ".json"
        if isfile(path) then
            delfile(path)
            RefreshConfigList()
            NoirUI:Notify("🗑️ Config", "Deleted: " .. name, "trash", "Notification")
        end
    end
    
    local function RefreshConfigList()
        for _, child in pairs(ConfigList:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end
        
        local configs = {}
        if isfolder(Window.ConfigFolder) then
            for _, file in pairs(listfiles(Window.ConfigFolder)) do
                local name = string.match(file, "([^/]+)%.json$")
                if name then
                    table.insert(configs, name)
                end
            end
        end
        
        for _, name in ipairs(configs) do
            local item = Instance.new("Frame", ConfigList)
            item.Size = UDim2.new(1, -10, 0, 30)
            item.BackgroundColor3 = NoirColors.BlockColor
            item.BackgroundTransparency = 1
            item.ZIndex = 152
            Instance.new("UICorner", item).CornerRadius = UDim.new(0, 6)
            
            local label = Instance.new("TextLabel", item)
