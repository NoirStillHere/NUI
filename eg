            local function updateCountBadge()
                if multiSelect and #selectedItems > 0 then
                    countBadge.Visible = true
                    countLabel.Text = tostring(#selectedItems)
                    local textWidth = #selectedItems * 8 + 16
                    countBadge.Size = UDim2.new(0, math.max(textWidth, 20), 0, 18)
                    countBadge.Position = UDim2.new(0.5, 0, 0.5, -9)
                    
                    if #selectedItems <= 2 then
                        selectedText.Text = table.concat(selectedItems, ", ")
                    else
                        selectedText.Text = #selectedItems .. " items selected"
                    end
                else
                    countBadge.Visible = false
                    selectedText.Text = ""
                end
            end
            
            local function renderOptions(options)
                for _, child in pairs(optionsScroll:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end
                
                for _, option in ipairs(options) do
                    local isSelected = false
                    for _, item in ipairs(selectedItems) do
                        if item == option then
                            isSelected = true
                            break
                        end
                    end
                    
                    local btn = Instance.new("TextButton", optionsScroll)
                    btn.Size = UDim2.new(1, -16, 0, 32)
                    btn.Position = UDim2.new(0, 8, 0, 0)
                    btn.BackgroundColor3 = isSelected and Color3.fromRGB(40, 40, 60) or Color3.fromRGB(22, 22, 30)
                    btn.BackgroundTransparency = 0.3
                    btn.Text = ""
                    btn.AutoButtonColor = false
                    btn.ZIndex = 1001
                    btn.Name = option
                    
                    btn.MouseEnter:Connect(function()
                        if not btn.BackgroundColor3 == Color3.fromRGB(40, 40, 60) then
                            TweenService:Create(btn, TweenInfo.new(0.1), {
                                BackgroundColor3 = Color3.fromRGB(35, 35, 45)
                            }):Play()
                        end
                    end)
                    btn.MouseLeave:Connect(function()
                        if not btn.BackgroundColor3 == Color3.fromRGB(40, 40, 60) then
                            TweenService:Create(btn, TweenInfo.new(0.1), {
                                BackgroundColor3 = Color3.fromRGB(22, 22, 30)
                            }):Play()
                        end
                    end)
                    
                    local checkBox = Instance.new("Frame", btn)
                    checkBox.Size = UDim2.new(0, 18, 0, 18)
                    checkBox.Position = UDim2.new(0, 10, 0.5, -9)
                    checkBox.BackgroundColor3 = isSelected and ACCENT or Color3.fromRGB(35, 35, 45)
                    checkBox.BackgroundTransparency = 0
                    checkBox.ZIndex = 1002
                    
                    local checkCorner = Instance.new("UICorner", checkBox)
                    checkCorner.CornerRadius = UDim.new(0, 4)
                    
                    local checkMark = Instance.new("TextLabel", checkBox)
                    checkMark.Size = UDim2.new(1, 0, 1, 0)
                    checkMark.BackgroundTransparency = 1
                    checkMark.Text = isSelected and "✓" or ""
                    checkMark.TextColor3 = Color3.new(1,1,1)
                    checkMark.TextSize = 12
                    checkMark.Font = "GothamBold"
                    checkMark.TextXAlignment = "Center"
                    checkMark.TextYAlignment = "Center"
                    checkMark.ZIndex = 1003
                    
                    local label = Instance.new("TextLabel", btn)
                    label.Size = UDim2.new(1, -50, 1, 0)
                    label.Position = UDim2.new(0, 35, 0, 0)
                    label.BackgroundTransparency = 1
                    label.Text = option
                    label.TextColor3 = isSelected and ACCENT or Color3.fromRGB(200, 200, 200)
                    label.TextSize = 12
                    label.Font = "Gotham"
                    label.TextXAlignment = "Left"
                    label.ZIndex = 1002
                    
                    btn.MouseButton1Click:Connect(function()
                        if multiSelect then
                            local found = false
                            for i, item in ipairs(selectedItems) do
                                if item == option then
                                    table.remove(selectedItems, i)
                                    found = true
                                    break
                                end
                            end
                            if not found then
                                table.insert(selectedItems, option)
                            end
                            
                            renderOptions(allOptions)
                            updateCountBadge()
                            if opt.OnChange then
                                pcall(opt.OnChange, selectedItems)
                            end
                        else
                            selectedItems = {option}
                            renderOptions(allOptions)
                            updateCountBadge()
                            if opt.Callback then
                                pcall(opt.Callback, option)
                            end
                            closePopup()
                        end
                    end)
                end
                
                task.wait()
                
                local contentHeight = optionsLayout.AbsoluteContentSize.Y + 10
                local mainAbsPos = Main.AbsolutePosition
                local mainAbsSize = Main.AbsoluteSize
                
                local popupWidth = math.min(container.AbsoluteSize.X * 1.2, 100)
                local maxHeight = mainAbsSize.Y - 40
                local scrollHeight = math.min(contentHeight, maxHeight - 46 - 50)
                
                optionsScroll.Size = UDim2.new(1, 0, 0, math.max(scrollHeight, 30))
                optionsScroll.CanvasSize = UDim2.new(0, 0, 0, contentHeight + 10)
                
                local totalHeight = 46 + scrollHeight + 50
                modalFrame.Size = UDim2.new(0, popupWidth, 0, math.max(totalHeight, 80))
                
                local posX = mainAbsPos.X - popupWidth - 10
                local posY = mainAbsPos.Y + 10
                
                if posX < 5 then
                    posX = 5
                end
                
                modalFrame.Position = UDim2.new(0, posX, 0, posY)
                actionFrame.Position = UDim2.new(0, 8, 1, -43)
            end
            
            local isPopupOpen = false
            
            local function openPopup()
                if isPopupOpen then return end
                isPopupOpen = true
                
                modalFrame.Visible = true
                modalFrame.BackgroundTransparency = 0.95
                
                modalFrame.Size = UDim2.new(0, 0, 0, 0)
                TweenService:Create(modalFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Size = UDim2.new(0, math.min(container.AbsoluteSize.X * 1.2, 100), 0, 250),
                    BackgroundTransparency = 0.95
                }):Play()
                
                arrow.Text = "▲"
                searchBox.Text = ""
                task.wait(0.1)
                searchBox:CaptureFocus()
                
                if opt.GetOptions then
                    allOptions = opt.GetOptions()
                end
                renderOptions(allOptions)
            end
            
            local function closePopup()
                if not isPopupOpen then return end
                isPopupOpen = false
                
                TweenService:Create(modalFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, 0, 0, 0),
                    BackgroundTransparency = 1
                }):Play()
                
                arrow.Text = "▼"
                task.wait(0.15)
                modalFrame.Visible = false
            end
            
            searchBox:GetPropertyChangedSignal("Text"):Connect(function()
                local search = searchBox.Text:lower()
                if search == "" then
                    renderOptions(allOptions)
                else
                    local filtered = {}
                    for _, option in ipairs(allOptions) do
                        if option:lower():find(search) then
                            table.insert(filtered, option)
                        end
                    end
                    renderOptions(filtered)
                end
            end)
            
            selectAllBtn.MouseButton1Click:Connect(function()
                if multiSelect then
                    selectedItems = {}
                    for _, option in ipairs(allOptions) do
                        table.insert(selectedItems, option)
                    end
                    renderOptions(allOptions)
                    updateCountBadge()
                    if opt.OnChange then
                        pcall(opt.OnChange, selectedItems)
                    end
                end
            end)
            
            clearBtn.MouseButton1Click:Connect(function()
                if multiSelect then
                    selectedItems = {}
                    renderOptions(allOptions)
                    updateCountBadge()
                    if opt.OnChange then
                        pcall(opt.OnChange, selectedItems)
                    end
                end
            end)
            
            confirmBtn.MouseButton1Click:Connect(function()
                if multiSelect then
                    if opt.Callback then
                        pcall(opt.Callback, selectedItems)
                    end
                end
                closePopup()
            end)
            
            triggerBtn.MouseButton1Click:Connect(function()
                PlaySound("Element")
                CreateClickScaleEffect(triggerBtn)
                
                if isPopupOpen then
                    closePopup()
                else
                    openPopup()
                end
            end)
            
            UIS.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if isPopupOpen and modalFrame.Visible then
                        local pos = input.Position
                        local absPos = modalFrame.AbsolutePosition
                        local absSize = modalFrame.AbsoluteSize
                        
                        if pos.X < absPos.X or pos.X > absPos.X + absSize.X or 
                           pos.Y < absPos.Y or pos.Y > absPos.Y + absSize.Y then
                            closePopup()
                        end
                    end
                end
            end)
            
            if opt.GetOptions then
                allOptions = opt.GetOptions()
            elseif opt.Options then
                allOptions = opt.Options
            end
            
            if opt.Default then
                if multiSelect and type(opt.Default) == "table" then
                    selectedItems = opt.Default
                elseif not multiSelect then
                    selectedItems = {opt.Default}
                end
            end
            
            task.wait()
            if multiSelect and #selectedItems > 0 then
                updateCountBadge()
            end
            
            local api = {
                Open = openPopup,
                Close = closePopup,
                IsOpen = function() return isPopupOpen end,
                GetSelected = function() return selectedItems end,
                SetSelected = function(items)
                    if multiSelect and type(items) == "table" then
                        selectedItems = items
                    elseif not multiSelect and type(items) == "string" then
                        selectedItems = {items}
                    end
                    updateCountBadge()
                    if opt.Callback then
                        pcall(opt.Callback, selectedItems)
                    end
                    renderOptions(allOptions)
                end,
                Refresh = function()
                    if opt.GetOptions then
                        allOptions = opt.GetOptions()
                    end
                    renderOptions(allOptions)
                end
            }
            
            container._dropdownApi = api
            return container, api
        end
        
