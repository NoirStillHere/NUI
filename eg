                    Main.Size = UDim2.new(0, 0, 0, 0)
                end
                Main.Visible = true
                Main.Size = UDim2.new(0, 0, 0, 0)
                Main.Position = mainDefaultPos
                TweenService:Create(Main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    Size = UDim2.new(0, 420, 0, 300)
                }):Play()
                if settings.UseBounce then
                    BounceEffect(Main, 20, 0.5)
                end
                if settings.UseConfetti then
                    CreateConfettiBurst(Main, 20)
                end
            end
        end
    end)
    
    function NoirUI:Notify(title, message, iconName, soundType)
        if soundType then
            PlaySound(soundType)
        else
            PlaySound("Notification")
        end
        local n = Instance.new("Frame", ScreenGui)
        n.Size = UDim2.new(0, 260, 0, 65)
        n.Position = UDim2.new(1, 20, 0.8, 0)
        n.BackgroundColor3 = settings.NotificationBackgroundColor
        local notifCorner = Instance.new("UICorner", n)
        notifCorner.CornerRadius = UDim.new(0, 8)
        local ns = Instance.new("UIStroke", n)
        ns.Color = ACCENT
        AddGlowStroke(n, ACCENT, 2, 5, 0.75)
        AddBlurOverlay(n, settings.NotificationBlur)
        if settings.UseGlow then
            local notifGlow = CreateUIGlow(n, ACCENT, 0.2, ScreenGui)
        end
        if settings.UseNeon then
            CreateNeonPulse(n, ACCENT, 0.3)
        end
        SetupBackground(n, settings.NotificationBackground, settings.NotificationBackgroundColor, 0.25)
        CreateSpringEffect(n)
        if settings.UseSlide then
            SlideIn(n, "right", 0.4)
        end
        if settings.UseFloating then
            CreateFloatingAnimation(n, 3, 0.5)
        end
        if iconName then
            local iconImg = ResolveIcon(iconName)
            if iconImg then
                local icon = Instance.new("ImageLabel", n)
                icon.Size = UDim2.new(0, 24, 0, 24)
                icon.Position = UDim2.new(0, 10, 0.5, -12)
                icon.BackgroundTransparency = 1
                icon.Image = iconImg
                icon.ImageColor3 = Color3.new(1, 1, 1)
                icon.ZIndex = 2
            end
        end
        local tl = Instance.new("TextLabel", n)
        tl.Size = UDim2.new(1, iconName and -45 or -15, 0, 20)
        tl.Position = UDim2.new(0, iconName and 40 or 15, 0, 5)
        tl.Text = title
        if useAutoContrast then
            tl.TextColor3 = GetContrastColor(settings.NotificationBackgroundColor)
        else
            tl.TextColor3 = ACCENT
        end
        tl.TextTransparency = 0
        tl.BackgroundTransparency = 1
        tl.Font = "GothamBold"
        tl.TextSize = 13
        tl.TextXAlignment = "Left"
        if settings.UseGlow then
            CreateGlowTextSlide(tl, {
                Color3.fromRGB(200, 200, 200),
                Color3.fromRGB(255, 255, 255),
                Color3.fromRGB(200, 200, 200)
            }, 1.5)
        end
        if settings.UseTyping then
            CreateTypingEffect(tl, title, 0.03)
        end
        if settings.UseGlitch then
            CreateGlitchEffect(tl, 4)
        end
        local ml = Instance.new("TextLabel", n)
        ml.Size = UDim2.new(1, iconName and -45 or -25, 0, 35)
        ml.Position = UDim2.new(0, iconName and 40 or 15, 0, 25)
        ml.Text = message
        ml.TextColor3 = Color3.new(1,1,1)
        ml.TextTransparency = 0
        ml.BackgroundTransparency = 1
        ml.TextWrapped = true
        ml.TextXAlignment = "Left"
        ml.TextYAlignment = "Top"
        ml.Font = "Gotham"
        ml.TextSize = 11
        for i, v in ipairs(NoirUI.Notifications) do
            TweenService:Create(v, TweenInfo.new(0.3), {Position = UDim2.new(1, -280, 0.8, -(i * 75))}):Play()
        end
        table.insert(NoirUI.Notifications, 1, n)
        TweenService:Create(n, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Position = UDim2.new(1, -280, 0.8, 0)}):Play()
        if settings.UseConfetti then
            CreateConfettiBurst(n, 10)
        end
        task.delay(4, function()
            TweenService:Create(n, TweenInfo.new(0.5), {Position = UDim2.new(1, 20, n.Position.Y.Scale, n.Position.Y.Offset), BackgroundTransparency = 1}):Play()
            task.wait(0.5)
            for i, v in ipairs(NoirUI.Notifications) do
                if v == n then
                    table.remove(NoirUI.Notifications, i)
                    break
                end
            end
            n:Destroy()
        end)
    end
    
    local Window = {}
    local allTabButtons = {}
    
    -- ============================================
    -- DYNAMIC UPDATE FUNCTIONS
    -- ============================================
    
    -- 1. Cập nhật Accent
    function Window:SetAccent(color)
        local newAccent = color or ACCENT
        -- Cập nhật stroke chính
        if MainStroke then
            MainStroke.Color = newAccent
        end
        -- Cập nhật glow stroke
        local glowStroke = Main:FindFirstChild("GlowStroke")
        if glowStroke then
            glowStroke.Color = newAccent
        end
        -- Cập nhật các tab đang active
        for _, btn in pairs(allTabButtons) do
            local stroke = btn:FindFirstChildWhichIsA("UIStroke")
            if stroke and stroke.Name ~= "GlowStroke" then
                stroke.Color = newAccent
            end
            local glow = btn:FindFirstChild("GlowStroke")
            if glow then
                glow.Color = newAccent
            end
            -- Cập nhật label active
            local label = btn:FindFirstChild("TextLabel")
            if label and label.TextColor3 == ACCENT then
                label.TextColor3 = newAccent
            end
        end
        -- Cập nhật loading bar
        if LoadingBar then
            LoadingBar.BackgroundColor3 = newAccent
        end
        -- Cập nhật stroke của các components
        for _, component in pairs(Window._components or {}) do
            if component._stroke then
                component._stroke.Color = newAccent
            end
        end
        -- Cập nhật các element trong tabs
        for _, tab in pairs(Window._tabs or {}) do
            if tab._elements then
                for _, elem in pairs(tab._elements) do
                    if elem:IsA("TextButton") and elem.BackgroundColor3 == ACCENT then
                        elem.BackgroundColor3 = newAccent
                    end
                end
            end
        end
        -- Lưu lại accent mới
        ACCENT = newAccent
        return true
    end
    
    -- 2. Cập nhật Main Background
    function Window:SetMainBackground(color, transparency)
        if Main then
            if color then
                Main.BackgroundColor3 = color
            end
            if transparency ~= nil then
                Main.BackgroundTransparency = transparency
            end
        end
        return true
    end
    
    -- 3. Cập nhật Blur
    function Window:SetBlur(amount)
        if Main then
            local blurWrapper = Main:FindFirstChild("BlurWrapper")
            if blurWrapper then
                local blur = blurWrapper:FindFirstChild("BlurOverlay")
                if blur then
                    blur.BackgroundTransparency = 1 - math.clamp(amount, 0, 1)
                end
            end
        end
        return true
    end
    
    -- 4. Cập nhật Sidebar
    function Window:SetSidebarBackground(color, transparency)
        if Side then
            if color then
                Side.BackgroundColor3 = color
            end
            if transparency ~= nil then
                Side.BackgroundTransparency = transparency
            end
        end
        return true
    end
    
    -- 5. Cập nhật Tab Background
    function Window:SetTabBackground(color)
        for _, btn in pairs(allTabButtons) do
            if btn then
                btn.BackgroundColor3 = color or Color3.fromRGB(20, 20, 20)
                local label = btn:FindFirstChild("TextLabel")
                if label and useAutoContrast then
                    label.TextColor3 = GetContrastColor(btn.BackgroundColor3)
                end
            end
        end
        return true
    end
    
    -- 6. Cập nhật Element Background
    function Window:SetElementBackground(color)
        -- Duyệt qua tất cả elements trong các tab
        for _, tab in pairs(Window._tabs or {}) do
            if tab._elements then
                for _, elem in pairs(tab._elements) do
                    if elem:IsA("Frame") or elem:IsA("TextButton") then
                        if elem.BackgroundColor3 ~= Color3.fromRGB(0,0,0) then
                            elem.BackgroundColor3 = color or Color3.fromRGB(25, 25, 35)
                        end
                    end
                end
            end
        end
        -- Cập nhật search frame
        for _, tab in pairs(Window._tabs or {}) do
            if tab._searchFrame then
                tab._searchFrame.BackgroundColor3 = color or Color3.fromRGB(20, 20, 20)
            end
        end
        return true
    end
    
    -- 7. Cập nhật Theme
    function Window:SetTheme(themeName)
        local theme = NoirUI.Themes[themeName]
        if not theme then return false end
        
        if theme.accent then self:SetAccent(theme.accent) end
        if theme.mainBg then self:SetMainBackground(theme.mainBg, 0) end
        if theme.blur ~= nil then self:SetBlur(theme.blur) end
        if theme.sidebarBg then self:SetSidebarBackground(theme.sidebarBg, theme.sidebarTrans or 0.8) end
        if theme.tabBg then self:SetTabBackground(theme.tabBg) end
        if theme.elementBg then self:SetElementBackground(theme.elementBg) end
        if Title and theme.textColor then
            Title.TextColor3 = theme.textColor
        end
        
        return true
    end
    
    -- 8. Cập nhật Background Image
    function Window:SetBackgroundImage(imageId, transparency)
        if Main then
            local bgImage = Main:FindFirstChild("_BackgroundImage")
            if bgImage then
                if imageId then
                    bgImage.Image = imageId
                end
                if transparency ~= nil then
                    bgImage.ImageTransparency = transparency
                end
            end
        end
        return true
    end
    
    -- 9. Cập nhật Float Icon
    function Window:SetFloatIcon(iconName)
        if TBtn then
            local clipGroup = TBtn:FindFirstChild("ClipGroup")
            if clipGroup then
                local icon = clipGroup:FindFirstChild("ImageLabel") or clipGroup:FindFirstChild("TextLabel")
                if icon then
                    local resolved = ResolveIcon(iconName)
                    if resolved then
                        if icon:IsA("ImageLabel") then
                            icon.Image = resolved
                        else
                            icon.Text = iconName
                        end
                    end
                end
            end
        end
        return true
    end
    
    -- 10. Cập nhật Title
    function Window:SetTitle(title)
        if Title then
            Title.Text = title or "NOIR HUB"
        end
        return true
    end
    
    -- 11. Cập nhật Description
    function Window:SetDescription(desc)
        if Description then
            Description.Text = desc or "NoirUI V3"
        end
        return true
    end
    
    -- 12. Cập nhật Confirm Background
    function Window:SetConfirmBackground(color)
        settings.ConfirmBackgroundColor = color or Color3.fromRGB(15, 15, 15)
        return true
    end
    
    -- 13. Cập nhật Notification Background
    function Window:SetNotificationBackground(color)
        settings.NotificationBackgroundColor = color or Color3.fromRGB(15, 15, 15)
        return true
    end
    
    -- 14. Cập nhật Sidebar Transparency
    function Window:SetSidebarTransparency(transparency)
        if Side then
            Side.BackgroundTransparency = transparency or 0.8
        end
        return true
    end
    
    -- 15. Lấy theme hiện tại
    function Window:GetCurrentTheme()
        return settings._currentTheme or "dark"
    end
    
    -- 16. Lấy accent hiện tại
    function Window:GetAccent()
        return ACCENT
    end
    
