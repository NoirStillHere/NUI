            optionsLayout.SortOrder = Enum.SortOrder.LayoutOrder
            
            local function renderOptions()
                for _, child in pairs(optionsScroll:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end
                
                for _, option in ipairs(options) do
                    local isSelected = false
                    if multi then
                        for _, item in pairs(selected) do
                            if item == option then isSelected = true break end
                        end
                    else
                        isSelected = option == selected
                    end
                    
                    local btn = Instance.new("TextButton", optionsScroll)
                    btn.Size = UDim2.new(1, -16, 0, 28)
                    btn.Position = UDim2.new(0, 8, 0, 0)
                    btn.BackgroundColor3 = isSelected and ACCENT or NoirColors.BlockColor
                    btn.BackgroundTransparency = isSelected and 0.7 or 0.9
                    btn.Text = option
                    btn.TextColor3 = NoirColors.SwitchColor
                    btn.TextSize = 12
                    btn.Font = Enum.Font.Gotham
                    btn.TextXAlignment = Enum.TextXAlignment.Left
                    btn.AutoButtonColor = false
                    btn.ZIndex = 102
                    
                    btn.MouseEnter:Connect(function()
                        TweenService:Create(btn, TweenInfo.new(0.1), {
                            BackgroundTransparency = 0.7
                        }):Play()
                    end)
                    btn.MouseLeave:Connect(function()
                        TweenService:Create(btn, TweenInfo.new(0.1), {
                            BackgroundTransparency = isSelected and 0.7 or 0.9
                        }):Play()
                    end)
                    
                    btn.MouseButton1Click:Connect(function()
                        NoirUI:PlaySound("Click")
                        if multi then
                            local found = false
                            for i, item in pairs(selected) do
                                if item == option then
                                    table.remove(selected, i)
                                    found = true
                                    break
                                end
                            end
                            if not found then
                                table.insert(selected, option)
                            end
                            valueText.Text = #selected .. " selected"
                            renderOptions()
                            if config.Callback then config.Callback(selected) end
                        else
                            selected = option
                            valueText.Text = option
                            renderOptions()
                            dropdownWindow.Visible = false
                            if config.Callback then config.Callback(option) end
                        end
                    end)
                end
                
                task.wait()
                local contentHeight = optionsLayout.AbsoluteContentSize.Y + 10
                optionsScroll.Size = UDim2.new(1, 0, 0, math.min(contentHeight, 150))
                optionsScroll.CanvasSize = UDim2.new(0, 0, 0, contentHeight + 10)
                dropdownWindow.Size = UDim2.new(0, math.min(container.AbsoluteSize.X, 250), 0, math.min(contentHeight, 150) + 5)
            end
            
            container.MouseButton1Click:Connect(function()
                NoirUI:PlaySound("Click")
                dropdownWindow.Visible = not dropdownWindow.Visible
                if dropdownWindow.Visible then
                    local absPos = container.AbsolutePosition
                    dropdownWindow.Position = UDim2.new(0, absPos.X, 0, absPos.Y + container.AbsoluteSize.Y)
                    renderOptions()
                    TweenService:Create(dropdownWindow, TweenInfo.new(0.15), {
                        BackgroundTransparency = 0.035
                    }):Play()
                else
                    TweenService:Create(dropdownWindow, TweenInfo.new(0.15), {
                        BackgroundTransparency = 1
                    }):Play()
                    task.wait(0.15)
                    dropdownWindow.Visible = false
                end
            end)
            
            UIS.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if dropdownWindow.Visible then
                        local pos = input.Position
                        local absPos = dropdownWindow.AbsolutePosition
                        local absSize = dropdownWindow.AbsoluteSize
                        if pos.X < absPos.X or pos.X > absPos.X + absSize.X or 
                           pos.Y < absPos.Y or pos.Y > absPos.Y + absSize.Y then
                            dropdownWindow.Visible = false
                            TweenService:Create(dropdownWindow, TweenInfo.new(0.15), {
                                BackgroundTransparency = 1
                            }):Play()
                            task.wait(0.15)
                            dropdownWindow.Visible = false
                        end
                    end
                end
            end)
            
            return container
        end
        
        -- ============================================
        -- 19. RETURN TAB
        -- ============================================
        table.insert(Window.Tabs, Tab)
        return Tab
    end
    
    -- ============================================
    -- 20. RUN INTRO
    -- ============================================
    CreateIntro()
    
    -- ============================================
    -- 21. RETURN WINDOW
    -- ============================================
    Window._frame = Main
    Window._side = Side
    Window._header = Header
    Window._tabContainer = TabContainer
    Window._tabScrolling = TabScrolling
    Window._configMenu = ConfigMenu
    Window._configName = ConfigName
    Window._refreshConfig = RefreshConfigList
    Window._toggleConfig = ToggleConfigMenu
    Window._saveConfig = SaveConfig
    Window._loadConfig = LoadConfig
    Window._deleteConfig = DeleteConfig
    
    table.insert(NoirUI._windows, Window)
    
    return Window
end

return NoirUI
