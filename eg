function NoirUI:_GetIcon(name, font_aws)
    if NoirUI.SecureMode then
        local AssetId;
        if font_aws then
            AssetId = (NoirUI.FontAwesome and NoirUI.FontAwesome[name]) or name;
        else
            local resolved = ResolveIcon(name)
            if resolved then
                return resolved
            end
            AssetId = (NoirUI.FontAwesome and NoirUI.FontAwesome[name]) or name;
        end;
        if AssetId and AssetId ~= nil then
            local asset = NoirUI:CacheImage(AssetId);
            return asset;
        end;
        return "";
    end;
    local resolved = ResolveIcon(name)
    if resolved then return resolved end
    if font_aws then
        return (NoirUI.FontAwesome and NoirUI.FontAwesome[name]) or name;
    end;
    return ResolveIcon(name) or (NoirUI.FontAwesome and NoirUI.FontAwesome[name]) or name;
end;

