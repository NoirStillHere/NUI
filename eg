                minusBtn.Font = "GothamBold"
                minusBtn.TextSize = 16
                minusBtn.AutoButtonColor = false
                Instance.new("UICorner", minusBtn).CornerRadius = UDim.new(0, 6)
                
                local plusBtn = Instance.new("TextButton", btnRow)
                plusBtn.Size = UDim2.new(0.45, 0, 1, 0)
                plusBtn.Position = UDim2.new(0.55, 0, 0, 0)
                plusBtn.BackgroundColor3 = currentTheme.container or Color3.fromRGB(14,14,18)
                plusBtn.Text = "+"
                plusBtn.TextColor3 = currentTheme.text or Color3.fromRGB(245,245,250)
                plusBtn.Font = "GothamBold"
                plusBtn.TextSize = 16
                plusBtn.AutoButtonColor = false
