function NoirUI:_AddDragBlacklist(Frame)
    local IsAdded = false;
    local BASE_TIME = 0.01;

    local SET_BLACKLIST = function(value)
        local index = table.find(NoirUI.DragBlacklist, Frame);
        if value and not NoirUI.IS_DRAG_MOVE then
            if not index then
                table.insert(NoirUI.DragBlacklist, Frame);
            end;
        else
            if index then
                table.remove(NoirUI.DragBlacklist, index);
            end;
        end;
    end;

    Frame.InputBegan:Connect(function(input)
        if NoirUI:_IsMouseOverFrame(Frame) then
            SET_BLACKLIST(true)
        end;
    end);

    Frame.InputEnded:Connect(function(input)
        SET_BLACKLIST(false);
    end);

    UserInputService.InputChanged:Connect(function()
        if not NoirUI:_IsMouseOverFrame(Frame) then
            SET_BLACKLIST(false);
        end
    end);
end;

function NoirUI:_GetWindowFromElement(Element)
    if NoirUI.WindowsNil[Element] then
        return NoirUI.WindowsNil[Element];
    end;

    for i,v : ScreenGui in next , NoirUI.Windows do
        if v and Element:IsDescendantOf(v) then
            return v;
        end;
    end;

    for Frame,Window in next , NoirUI.WindowsNil do
        if Element:IsDescendantOf(Frame) or Frame == Element then
            return Window;
        end;
    end;
end;

function NoirUI.__SIGNAL(default)
    local Bindable = Instance.new('BindableEvent');
    Bindable.Name = string.sub(tostring({}),7);
    Bindable:SetAttribute('Value',default);

    local Binds = {
        __signals = {}
    };

    function Binds:Connect(event)
        event(Bindable:GetAttribute("Value"));
        local signal = Bindable.Event:Connect(event);
        table.insert(Binds.__signals,signal);
        return signal;
    end;

    function Binds:Fire(value)
        local IsSame = Bindable:GetAttribute("Value") == value;
        Bindable:SetAttribute('Value',value);
        if not IsSame then
            Bindable:Fire(value);
        end;
    end;

    function Binds:GetValue()
        return Bindable:GetAttribute("Value");
    end;

    return Binds;
end;

function NoirUI:_Hover(Frame, OnHover, Release)
    Frame.MouseEnter:Connect(OnHover);
    Frame.MouseLeave:Connect(Release);
end;

function NoirUI.__CONFIG(config, default)
    config = config or {};
    for i,v in next , default do
        if config[i] == nil then
            config[i] = v;
        end;
    end;
    return config;
end;

function NoirUI:Drag(InputFrame, MoveFrame, Speed)
    local dragToggle: boolean = false;
    local dragStart: Vector3 = nil;
    local startPos: UDim2 = nil;
    local Tween = TweenInfo.new(Speed);

    local updateInput = function(input)
        local delta = input.Position - dragStart;
        local position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y);
        NoirUI:_Animation(MoveFrame, Tween, { Position = position });
    end;

    InputFrame.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and #NoirUI.DragBlacklist <= 0 then
            dragToggle = true
            dragStart = input.Position
            startPos = MoveFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragToggle = false;
                    NoirUI.IS_DRAG_MOVE = false;
                end
            end)
        end

        if not NoirUI.IsDrage and dragToggle then
            NoirUI.LastDrag = tick();
        end;

        NoirUI.IaDrag = dragToggle;
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch and #NoirUI.DragBlacklist <= 0 then
            if dragToggle then
                NoirUI.IS_DRAG_MOVE = true;
                updateInput(input)
            else
                NoirUI.IS_DRAG_MOVE = false;
            end
        else
            if #NoirUI.DragBlacklist > 0 then
                dragToggle = false
                NoirUI.IS_DRAG_MOVE = false;
            end
        end

        NoirUI.IaDrag = dragToggle;
    end);
end;

function NoirUI:_IsMobile()
    return UserInputService.TouchEnabled;
end;

