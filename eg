function NoirUI:Security(directory, Config)
    directory = directory or "NoirUI-Cache";

    if not isfolder(directory) then
        makefolder(directory);
    end;

    NoirUI.SecureMode = true;

    NoirUI.SecurityConfig = Config or {};

    NoirUI.CacheDirectory = directory;
end;

