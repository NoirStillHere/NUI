        function Tab:CreateToggleWithFlag(opt)
            local flagName = opt.Flag
            local toggle = self:CreateToggle({
                Name = opt.Name,
                Default = opt.Default,
                Subtitle = opt.Subtitle,
                Callback = opt.Callback,
            })
            
            toggle._value = opt.Default or false
            toggle.GetValue = function() return toggle._value end
            toggle.SetValue = function(value)
                toggle._value = value
                if toggle._updateUI then toggle._updateUI(value) end
                if opt.Callback then opt.Callback(value) end
            end
            toggle.SetDefault = function() toggle:SetValue(opt.Default or false) end
            toggle.Type = "Toggle"
            toggle._group = opt.Group
            
            if flagName then NoirUI:RegisterFlag(flagName, toggle) end
            return toggle
        end
        
        function Tab:CreateSliderWithFlag(opt)
            local flagName = opt.Flag
            local slider = self:CreateSlider({
                Name = opt.Name,
                Default = opt.Default,
                range = opt.range or {0, 100},
                increment = opt.increment or 1,
                Subtitle = opt.Subtitle,
                Callback = opt.Callback,
            })
            
            slider._value = opt.Default or 0
            slider.GetValue = function() return slider._value end
            slider.SetValue = function(value)
                slider._value = value
                if slider._update then slider._update(value) end
                if opt.Callback then opt.Callback(value) end
            end
            slider.SetDefault = function() slider:SetValue(opt.Default or 0) end
            slider.Type = "Slider"
            slider._group = opt.Group
            
            if flagName then NoirUI:RegisterFlag(flagName, slider) end
            return slider
        end
        
