        self.Visible = false
        Frame.BackgroundTransparency = 1
        Frame.Size = UDim2.new(0, settings.Width, 0, 0)
        shadow:Render(false)
    end
    
    function ContextMenu:Destroy()
        self:Hide()
        Frame:Destroy()
    end
    
    UIS.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            if self.Visible then
                local pos = input.Position
                local framePos = Frame.AbsolutePosition
                local frameSize = Frame.AbsoluteSize
                if pos.X < framePos.X or pos.X > framePos.X + frameSize.X or
                   pos.Y < framePos.Y or pos.Y > framePos.Y + frameSize.Y then
                    self:Hide()
                end
            end
        end
    end)
    
    UIS.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            if self.Visible then
                self:Hide()
            else
                self:Show(input.Position)
            end
        end
    end)
    
    return ContextMenu
end

