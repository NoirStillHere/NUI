            -- Dropdown Popup (giống CK)
            local dropdownWindow = Instance.new("Frame", container.Parent)
            dropdownWindow.Name = "DropdownPopup"
            dropdownWindow.Size = UDim2.new(0, 0, 0, 0)
            dropdownWindow.Position = UDim2.new(0, 0, 0, 0)
            dropdownWindow.BackgroundColor3 = Color3.fromRGB(20, 22, 27)
            dropdownWindow.BackgroundTransparency = 1
            dropdownWindow.Visible = false
            dropdownWindow.ClipsDescendants = true
            dropdownWindow.ZIndex = 500
            dropdownWindow.AutomaticSize = Enum.AutomaticSize.None
            
            local modalCorner = Instance.new("UICorner", dropdownWindow)
            modalCorner.CornerRadius = UDim.new(0, 10)
            
            local modalStroke = Instance.new("UIStroke", dropdownWindow)
            modalStroke.Color = Color3.fromRGB(45, 48, 58)
            modalStroke.Thickness = 1
            modalStroke.Transparency = 0.65
            
            -- Search
            local searchFrame = Instance.new("Frame", dropdownWindow)
            searchFrame.Size = UDim2.new(1, -16, 0, 28)
            searchFrame.Position = UDim2.new(0, 8, 0, 8)
            searchFrame.BackgroundColor3 = Color3.fromRGB(26, 28, 36)
            searchFrame.BackgroundTransparency = 0.5
            searchFrame.ZIndex = 501
            
            local searchCorner = Instance.new("UICorner", searchFrame)
            searchCorner.CornerRadius = UDim.new(0, 4)
            
            local searchIcon = Instance.new("ImageLabel", searchFrame)
            searchIcon.Size = UDim2.new(0, 14, 0, 14)
            searchIcon.Position = UDim2.new(0, 8, 0.5, -7)
            searchIcon.BackgroundTransparency = 1
            searchIcon.Image = ResolveIcon("search") or "rbxassetid://5107220207"
            searchIcon.ImageColor3 = Color3.fromRGB(150, 150, 150)
            searchIcon.ZIndex = 502
            
            local searchBox = Instance.new("TextBox", searchFrame)
            searchBox.Size = UDim2.new(1, -30, 1, 0)
            searchBox.Position = UDim2.new(0, 28, 0, 0)
            searchBox.BackgroundTransparency = 1
            searchBox.PlaceholderText = "Tìm kiếm..."
            searchBox.Text = ""
            searchBox.TextColor3 = Color3.fromRGB(255, 255, 255)
            searchBox.TextTransparency = 0.35
            searchBox.Font = "Gotham"
            searchBox.TextSize = 11
            searchBox.ClearTextOnFocus = false
            searchBox.ZIndex = 502
            
            -- Options list
            local optionsScroll = Instance.new("ScrollingFrame", dropdownWindow)
            optionsScroll.Size = UDim2.new(1, 0, 0, 0)
            optionsScroll.Position = UDim2.new(0, 0, 0, 44)
            optionsScroll.BackgroundTransparency = 1
            optionsScroll.ScrollBarThickness = 3
            optionsScroll.ScrollBarImageColor3 = ACCENT
            optionsScroll.ScrollBarImageTransparency = 0.5
            optionsScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
            optionsScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
            optionsScroll.ZIndex = 501
            optionsScroll.BorderSizePixel = 0
            optionsScroll.ClipsDescendants = true
            
            local optionsLayout = Instance.new("UIListLayout", optionsScroll)
            optionsLayout.Padding = UDim.new(0, 2)
            optionsLayout.SortOrder = Enum.SortOrder.LayoutOrder
            
            local function updateCountBadge()
                if multiSelect and #selectedItems > 0 then
                    valueText.Text = #selectedItems .. " selected"
                else
                    valueText.Text = selectedItems[1] or ""
                end
            end
            
            local function renderOptions(options)
                for _, child in pairs(optionsScroll:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end
                
                for _, option in ipairs(options) do
                    local isSelected = false
                    for _, item in ipairs(selectedItems) do
                        if item == option then
                            isSelected = true
                            break
                        end
                    end
                    
                    local btn = Instance.new("TextButton", optionsScroll)
                    btn.Size = UDim2.new(1, -16, 0, 28)
                    btn.Position = UDim2.new(0, 8, 0, 0)
                    btn.BackgroundColor3 = isSelected and Color3.fromRGB(40, 40, 60) or Color3.fromRGB(22, 22, 30)
                    btn.BackgroundTransparency = 0.3
                    btn.Text = option
                    btn.TextColor3 = isSelected and ACCENT or Color3.fromRGB(200, 200, 200)
                    btn.TextSize = 12
                    btn.Font = "Gotham"
                    btn.TextXAlignment = "Left"
                    btn.AutoButtonColor = false
                    btn.ZIndex = 502
                    btn.Name = option
                    
                    local checkBox = Instance.new("Frame", btn)
                    checkBox.Size = UDim2.new(0, 16, 0, 16)
                    checkBox.Position = UDim2.new(1, -24, 0.5, -8)
                    checkBox.BackgroundColor3 = isSelected and ACCENT or Color3.fromRGB(35, 35, 45)
                    checkBox.BackgroundTransparency = 0
                    checkBox.ZIndex = 503
                    
                    local checkCorner = Instance.new("UICorner", checkBox)
                    checkCorner.CornerRadius = UDim.new(0, 3)
                    
                    local checkMark = Instance.new("TextLabel", checkBox)
                    checkMark.Size = UDim2.new(1, 0, 1, 0)
                    checkMark.BackgroundTransparency = 1
                    checkMark.Text = isSelected and "✓" or ""
                    checkMark.TextColor3 = Color3.new(1,1,1)
                    checkMark.TextSize = 11
                    checkMark.Font = "GothamBold"
                    checkMark.TextXAlignment = "Center"
                    checkMark.TextYAlignment = "Center"
                    checkMark.ZIndex = 504
                    
                    btn.MouseEnter:Connect(function()
                        if not btn.BackgroundColor3 == Color3.fromRGB(40, 40, 60) then
                            TweenService:Create(btn, TweenInfo.new(0.1), {
                                BackgroundColor3 = Color3.fromRGB(35, 35, 45)
                            }):Play()
                        end
                    end)
                    btn.MouseLeave:Connect(function()
                        if not btn.BackgroundColor3 == Color3.fromRGB(40, 40, 60) then
                            TweenService:Create(btn, TweenInfo.new(0.1), {
                                BackgroundColor3 = Color3.fromRGB(22, 22, 30)
                            }):Play()
                        end
                    end)
                    
                    btn.MouseButton1Click:Connect(function()
                        if multiSelect then
                            local found = false
                            for i, item in ipairs(selectedItems) do
                                if item == option then
                                    table.remove(selectedItems, i)
                                    found = true
                                    break
                                end
                            end
                            if not found then
                                table.insert(selectedItems, option)
                            end
                            
                            renderOptions(allOptions)
                            updateCountBadge()
                            if opt.OnChange then
                                pcall(opt.OnChange, selectedItems)
                            end
                        else
                            selectedItems = {option}
                            renderOptions(allOptions)
                            updateCountBadge()
                            if opt.Callback then
                                pcall(opt.Callback, option)
                            end
                            closePopup()
                        end
                    end)
                end
                
                task.wait()
                local contentHeight = optionsLayout.AbsoluteContentSize.Y + 10
                local maxHeight = 200
                local scrollHeight = math.min(contentHeight, maxHeight)
                optionsScroll.Size = UDim2.new(1, 0, 0, scrollHeight)
                optionsScroll.CanvasSize = UDim2.new(0, 0, 0, contentHeight + 10)
                
                local totalHeight = 44 + scrollHeight + 10
                dropdownWindow.Size = UDim2.new(0, math.min(container.AbsoluteSize.X, 250), 0, totalHeight)
            end
            
            local isPopupOpen = false
            
            local function openPopup()
                if isPopupOpen then return end
                isPopupOpen = true
                
                local absPos = container.AbsolutePosition
                local parentAbsPos = parent.AbsolutePosition
                
                dropdownWindow.Position = UDim2.new(0, absPos.X - parentAbsPos.X, 0, absPos.Y - parentAbsPos.Y + container.AbsoluteSize.Y + 2)
                dropdownWindow.Visible = true
                dropdownWindow.BackgroundTransparency = 0.035
                
                dropdownWindow.Size = UDim2.new(0, 0, 0, 0)
                TweenService:Create(dropdownWindow, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Size = UDim2.new(0, math.min(container.AbsoluteSize.X, 250), 0, 200),
                    BackgroundTransparency = 0.035
                }):Play()
                
                arrow.Rotation = 180
                searchBox.Text = ""
                task.wait(0.1)
                searchBox:CaptureFocus()
                
                if opt.GetOptions then
                    allOptions = opt.GetOptions()
                end
                renderOptions(allOptions)
            end
            
            local function closePopup()
                if not isPopupOpen then return end
                isPopupOpen = false
                
                TweenService:Create(dropdownWindow, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, 0, 0, 0),
                    BackgroundTransparency = 1
                }):Play()
                
                arrow.Rotation = 0
                task.wait(0.15)
                dropdownWindow.Visible = false
            end
            
            searchBox:GetPropertyChangedSignal("Text"):Connect(function()
                local search = searchBox.Text:lower()
                if search == "" then
                    renderOptions(allOptions)
                else
                    local filtered = {}
                    for _, option in ipairs(allOptions) do
                        if option:lower():find(search) then
                            table.insert(filtered, option)
                        end
                    end
                    renderOptions(filtered)
                end
            end)
            
            container.MouseButton1Click:Connect(function()
                PlaySound("Element")
                CreateClickScaleEffect(container)
                
                if isPopupOpen then
                    closePopup()
                else
                    openPopup()
                end
            end)
            
            UIS.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if isPopupOpen and dropdownWindow.Visible then
                        local pos = input.Position
                        local absPos = dropdownWindow.AbsolutePosition
                        local absSize = dropdownWindow.AbsoluteSize
                        
                        if pos.X < absPos.X or pos.X > absPos.X + absSize.X or 
                           pos.Y < absPos.Y or pos.Y > absPos.Y + absSize.Y then
                            closePopup()
                        end
                    end
                end
            end)
            
            if opt.GetOptions then
                allOptions = opt.GetOptions()
            elseif opt.Options then
                allOptions = opt.Options
            end
            
            if opt.Default then
                if multiSelect and type(opt.Default) == "table" then
                    selectedItems = opt.Default
                elseif not multiSelect then
                    selectedItems = {opt.Default}
                end
            end
            
            task.wait()
            updateCountBadge()
            
            local api = {
                Open = openPopup,
                Close = closePopup,
                IsOpen = function() return isPopupOpen end,
                GetSelected = function() return selectedItems end,
                SetSelected = function(items)
                    if multiSelect and type(items) == "table" then
                        selectedItems = items
                    elseif not multiSelect and type(items) == "string" then
                        selectedItems = {items}
                    end
                    updateCountBadge()
                    if opt.Callback then
                        pcall(opt.Callback, selectedItems)
                    end
                    renderOptions(allOptions)
                end,
                Refresh = function()
                    if opt.GetOptions then
                        allOptions = opt.GetOptions()
                    end
                    renderOptions(allOptions)
                end
            }
            
            container._dropdownApi = api
            return container, api
        end
        
