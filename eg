        self.Visible = true
        
        local contentSize = layout.AbsoluteContentSize
        local height = contentSize.Y + 10
        
        local screenSize = NoirUI.ScreenGui and NoirUI.ScreenGui.AbsoluteSize or Vector2.new(1920, 1080)
        local x = position.X
        local y = position.Y
        
        if x + settings.Width > screenSize.X then
            x = screenSize.X - settings.Width - 5
        end
        if y + height > screenSize.Y then
            y = screenSize.Y - height - 5
        end
        
        Frame.Position = UDim2.new(0, x, 0, y)
        Frame.Size = UDim2.new(0, settings.Width, 0, height)
        Frame.BackgroundTransparency = 0
        shadow:Render(true)
    end
    
