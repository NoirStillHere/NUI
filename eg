    -- ============================================
    -- SEGMENTED CONTROL
    -- ============================================
    local function CreateSegmentedControl(parent, options, default, callback)
        local container = Instance.new("Frame", parent)
        container.Size = UDim2.new(0.95, 0, 0, 32)
        container.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        container.BackgroundTransparency = 0.5
        Instance.new("UICorner", container).CornerRadius = UDim.new(0, 8)
        container.LayoutOrder = #parent:GetChildren() + 1
        container.ClipsDescendants = true
        
        local selected = default or options[1]
        local buttons = {}
        
        local layout = Instance.new("UIListLayout", container)
        layout.FillDirection = "Horizontal"
        layout.HorizontalAlignment = "Center"
        layout.Padding = UDim.new(0, 2)
        
        for i, opt in ipairs(options) do
            local btn = Instance.new("TextButton", container)
            btn.Size = UDim2.new(0, 70, 1, -4)
            btn.Position = UDim2.new(0, 2, 0, 2)
            btn.Text = opt
            btn.TextColor3 = Color3.new(1,1,1)
            btn.TextTransparency = 0
            btn.TextSize = 11
            btn.Font = "GothamMedium"
            btn.BackgroundColor3 = (opt == default) and ACCENT or Color3.fromRGB(35, 35, 45)
            btn.BackgroundTransparency = 0
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
            btn.AutoButtonColor = false
            btn.ZIndex = 2
            if settings.UseRipple then
                CreateRippleEffect(btn, ACCENT, 0.3)
            end
            if settings.UseNeon then
                CreateNeonPulse(btn, ACCENT, 0.3)
            end
            table.insert(buttons, btn)
            
            btn.MouseButton1Click:Connect(function()
                selected = opt
                for _, b in ipairs(buttons) do
                    TweenService:Create(b, TweenInfo.new(0.2), {
                        BackgroundColor3 = (b == btn) and ACCENT or Color3.fromRGB(35, 35, 45)
                    }):Play()
                end
                if settings.UsePop then
                    PopEffect(btn, 1.1)
                end
                if callback then callback(opt) end
            end)
        end
        
        return container, buttons
    end
    
    -- ============================================
    -- PROGRESS BAR
    -- ============================================
    local function CreateProgressBar(parent, value, max, color)
        local container = Instance.new("Frame", parent)
        container.Size = UDim2.new(0.95, 0, 0, 22)
        container.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        container.BackgroundTransparency = 0.5
        Instance.new("UICorner", container).CornerRadius = UDim.new(0, 4)
        container.LayoutOrder = #parent:GetChildren() + 1
        container.ClipsDescendants = true
        
        local fill = Instance.new("Frame", container)
        fill.Size = UDim2.new(value/max, 0, 1, 0)
        fill.BackgroundColor3 = color or ACCENT
        Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 4)
        fill.BackgroundTransparency = 0
        if settings.UseNeon then
            CreateNeonPulse(fill, color or ACCENT, 0.3)
        end
        
        local label = Instance.new("TextLabel", container)
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = math.floor(value/max * 100) .. "%"
        label.TextColor3 = Color3.new(1,1,1)
        label.TextSize = 10
        label.Font = "GothamBold"
        label.TextXAlignment = "Center"
        label.ZIndex = 2
        
        local function update(newValue, newMax)
            local v = newValue or value
            local m = newMax or max
            local percent = math.clamp(v/m, 0, 1)
            TweenService:Create(fill, TweenInfo.new(0.3), {
                Size = UDim2.new(percent, 0, 1, 0)
            }):Play()
            label.Text = math.floor(percent * 100) .. "%"
        end
        
        return container, update
    end
    
    -- ============================================
    -- RADIO GROUP
    -- ============================================
    local function CreateRadioGroup(parent, options, default, callback)
        local container = Instance.new("Frame", parent)
        container.Size = UDim2.new(0.95, 0, 0, #options * 30 + 10)
        container.BackgroundColor3 = Color3.fromRGB(18, 18, 26)
        container.BackgroundTransparency = 0.5
        Instance.new("UICorner", container).CornerRadius = UDim.new(0, 8)
        container.LayoutOrder = #parent:GetChildren() + 1
        container.ClipsDescendants = true
        
        local selected = default or options[1]
        local btns = {}
        
        local layout = Instance.new("UIListLayout", container)
        layout.Padding = UDim.new(0, 2)
        layout.SortOrder = "LayoutOrder"
        
        for i, opt in ipairs(options) do
            local btn = Instance.new("TextButton", container)
            btn.Size = UDim2.new(1, -20, 0, 28)
            btn.Position = UDim2.new(0, 10, 0, 0)
            btn.BackgroundTransparency = 1
            btn.Text = "  " .. opt
            btn.TextColor3 = (opt == default) and ACCENT or Color3.fromRGB(200, 200, 200)
            btn.TextSize = 12
            btn.Font = "GothamMedium"
            btn.TextXAlignment = "Left"
            btn.AutoButtonColor = false
            btn.LayoutOrder = i
            if settings.UseRipple then
                CreateRippleEffect(btn, ACCENT, 0.3)
            end
            
            local dot = Instance.new("Frame", btn)
            dot.Size = UDim2.new(0, 16, 0, 16)
            dot.Position = UDim2.new(1, -26, 0.5, -8)
            dot.BackgroundColor3 = (opt == default) and ACCENT or Color3.fromRGB(50, 50, 60)
            Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
            dot.BackgroundTransparency = 0
            
            local inner = Instance.new("Frame", dot)
            inner.Size = UDim2.new(0, 8, 0, 8)
            inner.Position = UDim2.new(0.25, 0, 0.25, 0)
            inner.BackgroundColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", inner).CornerRadius = UDim.new(1, 0)
            inner.Visible = (opt == default)
            
            btn.MouseButton1Click:Connect(function()
                selected = opt
                for _, b in ipairs(btns) do
                    b.TextColor3 = (b == btn) and ACCENT or Color3.fromRGB(200, 200, 200)
                    local d = b:FindFirstChild("Frame")
                    if d then
                        local inn = d:FindFirstChild("Frame")
                        if inn then inn.Visible = (b == btn) end
                        d.BackgroundColor3 = (b == btn) and ACCENT or Color3.fromRGB(50, 50, 60)
                    end
                end
                if settings.UsePop then
                    PopEffect(btn, 1.1)
                end
                if callback then callback(opt) end
            end)
            
            table.insert(btns, btn)
        end
        
        return container, btns
    end
    
