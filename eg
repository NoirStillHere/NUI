    function Window:SetBlur(intensity)
        if not self._blur then
            self._blur = BlurManager:Create(Main)
        end
        if intensity ~= nil then
            self._blur:SetIntensity(intensity)
        end
        return self._blur
    end
    
    function Window:ToggleBlur()
        if self._blur then
            self._blur:Toggle()
        end
    end
    
    function Window:RemoveBlur()
        if self._blur then
            self._blur:Destroy()
            self._blur = nil
        end
    end
    
    function Window:EnableShadow(rolling)
        if not self._shadow then
            self._shadow = NoirUI:CreateShadow(Main, rolling or false)
        end
        self._shadow:Render(true)
        return self._shadow
    end
    
    function Window:DisableShadow()
        if self._shadow then
            self._shadow:Render(false)
        end
    end
    
    function Window:ToggleShadow()
        if self._shadow then
            local current = self._shadow._visible or false
            self._shadow:Render(not current)
            self._shadow._visible = not current
        end
    end
    
    function Window:Hide()
        Main.Visible = false
        TBtn.Visible = true
    end
    
    function Window:Show()
        Main.Visible = true
        TBtn.Visible = false
    end
    
