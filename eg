                pvw.BackgroundColor3 = finalCol
                pvw.BackgroundTransparency = transparency
                satBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                cursor.Position = UDim2.new(s, 0, 1 - v, 0)
                hCursor.Position = UDim2.new(0, 0, h, 0)
                transSlider.BackgroundColor3 = finalCol
                transCursor.Position = UDim2.new(transparency, 0, 0.5, 0)
                hexLabel.Text = "#" .. finalCol:ToHex()
                
                local lightness = (s + v) / 2
                if lightness > 0.6 then
                    cursor.ImageColor3 = Color3.new(0, 0, 0)
                else
                    cursor.ImageColor3 = Color3.new(1, 1, 1)
                end
                
                if opt.Callback then 
                    pcall(function() opt.Callback(finalCol, transparency) end)
                end
            end
            
            local isDraggingSat = false
            local isDraggingHue = false
            local isDraggingTrans = false
            
            satBox.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDraggingSat = true
                    local relativeX = math.clamp((input.Position.X - satBox.AbsolutePosition.X) / satBox.AbsoluteSize.X, 0, 1)
                    local relativeY = math.clamp((input.Position.Y - satBox.AbsolutePosition.Y) / satBox.AbsoluteSize.Y, 0, 1)
                    s = math.clamp(relativeX, 0, 1)
                    v = math.clamp(1 - relativeY, 0, 1)
                    UpdateColor()
                end
            end)
            
            hueSlider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDraggingHue = true
                    local relativeY = math.clamp((input.Position.Y - hueSlider.AbsolutePosition.Y) / hueSlider.AbsoluteSize.Y, 0, 1)
                    h = math.clamp(relativeY, 0, 1)
                    UpdateColor()
                end
            end)
            
            transSlider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDraggingTrans = true
                    local relativeX = math.clamp((input.Position.X - transSlider.AbsolutePosition.X) / transSlider.AbsoluteSize.X, 0, 1)
                    transparency = math.clamp(relativeX, 0, 1)
                    UpdateColor()
                end
            end)
            
            local function onInputChanged(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                    if isDraggingSat then
                        local relativeX = math.clamp((input.Position.X - satBox.AbsolutePosition.X) / satBox.AbsoluteSize.X, 0, 1)
                        local relativeY = math.clamp((input.Position.Y - satBox.AbsolutePosition.Y) / satBox.AbsoluteSize.Y, 0, 1)
                        s = math.clamp(relativeX, 0, 1)
                        v = math.clamp(1 - relativeY, 0, 1)
                        UpdateColor()
                    elseif isDraggingHue then
                        local relativeY = math.clamp((input.Position.Y - hueSlider.AbsolutePosition.Y) / hueSlider.AbsoluteSize.Y, 0, 1)
                        h = math.clamp(relativeY, 0, 1)
                        UpdateColor()
                    elseif isDraggingTrans then
                        local relativeX = math.clamp((input.Position.X - transSlider.AbsolutePosition.X) / transSlider.AbsoluteSize.X, 0, 1)
                        transparency = math.clamp(relativeX, 0, 1)
                        UpdateColor()
                    end
                end
            end
            
            local function onInputEnded(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDraggingSat = false
                    isDraggingHue = false
                    isDraggingTrans = false
                end
            end
            
            UIS.InputChanged:Connect(onInputChanged)
            UIS.InputEnded:Connect(onInputEnded)
            
            local isOpen = false
            
            local function openColorPicker()
                if isOpen then return end
                isOpen = true
                
                local absPos = f.AbsolutePosition
                local parentAbsPos = parent.AbsolutePosition
                
                colorPickerWindow.Position = UDim2.new(0, absPos.X - parentAbsPos.X + f.AbsoluteSize.X + 10, 0, absPos.Y - parentAbsPos.Y)
                colorPickerWindow.Visible = true
                colorPickerWindow.BackgroundTransparency = 0.035
                
                colorPickerWindow.Size = UDim2.new(0, 0, 0, 0)
                TweenService:Create(colorPickerWindow, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Size = UDim2.new(0, 200, 0, 240),
                    BackgroundTransparency = 0.035
                }):Play()
            end
            
            local function closeColorPicker()
                if not isOpen then return end
                isOpen = false
                
                TweenService:Create(colorPickerWindow, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, 0, 0, 0),
                    BackgroundTransparency = 1
                }):Play()
                
                task.wait(0.15)
                colorPickerWindow.Visible = false
            end
            
            pvw.MouseButton1Click:Connect(function()
                PlaySound("Element")
                CreateClickScaleEffect(pvw)
                
                if isOpen then
                    closeColorPicker()
                else
                    openColorPicker()
                end
            end)
            
            UIS.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if isOpen and colorPickerWindow.Visible then
                        local pos = input.Position
                        local absPos = colorPickerWindow.AbsolutePosition
                        local absSize = colorPickerWindow.AbsoluteSize
                        
                        if pos.X < absPos.X or pos.X > absPos.X + absSize.X or 
                           pos.Y < absPos.Y or pos.Y > absPos.Y + absSize.Y then
                            local previewPos = pvw.AbsolutePosition
                            local previewSize = pvw.AbsoluteSize
                            if pos.X < previewPos.X or pos.X > previewPos.X + previewSize.X or 
                               pos.Y < previewPos.Y or pos.Y > previewPos.Y + previewSize.Y then
                                closeColorPicker()
                            end
                        end
                    end
                end
            end)
            
            UpdateColor()
            
            local api = {
                SetValue = function(color, trans)
                    h, s, v = color:ToHSV()
                    transparency = trans or 0
                    UpdateColor()
                end,
                GetValue = function()
                    return {
                        Color = Color3.fromHSV(h, s, v),
                        Transparency = transparency
                    }
                end,
                Open = openColorPicker,
                Close = closeColorPicker,
                IsOpen = function() return isOpen end
            }
            
            f._colorPickerApi = api
            return f, api
        end
        
