-- ============================================
-- BLUR OVERLAY (CÓ CẮT THEO VIỀN - CORNER TÙY CHỈNH)
-- ============================================
local function AddBlurOverlay(parent, blurAmount, customCornerRadius)
    if not parent or not blurAmount or blurAmount <= 0 then return nil end
    
    local existing = parent:FindFirstChild("BlurOverlay")
    if existing then existing:Destroy() end

    local blur = Instance.new("Frame", parent)
    blur.Name = "BlurOverlay"
    blur.Size = UDim2.new(1, 0, 1, 0)
    blur.Position = UDim2.new(0, 0, 0, 0)
    blur.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    blur.BackgroundTransparency = 1 - math.clamp(blurAmount, 0, 1)
    blur.BorderSizePixel = 0
    blur.ZIndex = 1
    
    local parentCorner = parent:FindFirstChild("UICorner")
    if parentCorner then
        local corner = Instance.new("UICorner", blur)
        corner.CornerRadius = parentCorner.CornerRadius
    elseif customCornerRadius then
        local corner = Instance.new("UICorner", blur)
        corner.CornerRadius = customCornerRadius
    else
        local corner = Instance.new("UICorner", blur)
        corner.CornerRadius = UDim.new(0, 12)
    end
    
    local gradient = Instance.new("UIGradient", blur)
    gradient.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),
        NumberSequenceKeypoint.new(0.03, 0.05),
        NumberSequenceKeypoint.new(0.97, 0.05),
        NumberSequenceKeypoint.new(1, 0)
    })
    
    for _, child in pairs(parent:GetChildren()) do
        if child ~= blur and child:IsA("GuiObject") then
            if child.ZIndex <= 1 then
                child.ZIndex = 2
            end
        end
    end
    
    local connection
    connection = parent.ChildAdded:Connect(function(child)
        if child ~= blur and child:IsA("GuiObject") then
            child.ZIndex = math.max(child.ZIndex or 2, 2)
        end
    end)
    
    table.insert(NoirUI.Connections, connection)

    return blur
end

local function UpdateBlurCorner(parent, newCornerRadius)
    local blur = parent:FindFirstChild("BlurOverlay")
    if blur then
        local corner = blur:FindFirstChild("UICorner")
        if corner then
            corner.CornerRadius = newCornerRadius
        end
    end
end

