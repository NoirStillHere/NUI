-- INFO POPUP (GIỐNG COMPKILLER)
-- ============================================
local function CreateInfoPopup(button, text, parent)
    parent = parent or game.CoreGui:FindFirstChild("NoirUI_V4_Ultimate")
    if not parent then return end
    
    local popup = Instance.new("Frame", parent)
    popup.Size = UDim2.new(0, 0, 0, 0)
    popup.Position = UDim2.new(0, 0, 0, 0)
    popup.BackgroundColor3 = NoirColors.BGDBColor
    popup.BackgroundTransparency = 1
    popup.Visible = false
    popup.ClipsDescendants = true
    popup.ZIndex = 200
    popup.Name = "InfoPopup"
    
    Instance.new("UICorner", popup).CornerRadius = UDim.new(0, 6)
    
    local stroke = Instance.new("UIStroke", popup)
    stroke.Color = NoirColors.StrokeColor
    stroke.Thickness = 1
    stroke.Transparency = 1
    
    -- Shadow
    for i = 1, 3 do
        local shadow = Instance.new("UIStroke", popup)
        shadow.Color = Color3.fromRGB(0, 0, 0)
        shadow.Thickness = 6 - i
        shadow.Transparency = 0.9 + (i * 0.025)
        shadow.ZIndex = -1
    end
    
    local content = Instance.new("TextLabel", popup)
    content.Size = UDim2.new(1, -20, 1, -10)
    content.Position = UDim2.new(0, 10, 0, 5)
    content.BackgroundTransparency = 1
    content.Text = text or "Thông tin"
    content.TextColor3 = NoirColors.SwitchColor
    content.TextSize = 11
    content.TextTransparency = 1
    content.Font = Enum.Font.GothamMedium
    content.TextWrapped = true
    content.TextXAlignment = Enum.TextXAlignment.Left
    content.TextYAlignment = Enum.TextYAlignment.Top
    content.ZIndex = 201
    content.Name = "Content"
    
    local isVisible = false
    local hideTimer = nil
    
    local function updatePopup()
        local textSize = TextService:GetTextSize(content.Text, content.TextSize, content.Font, Vector2.new(150, math.huge))
        local width = math.min(textSize.X + 30, 200)
        local height = math.max(textSize.Y + 15, 30)
        
        popup.Size = UDim2.new(0, width, 0, height)
        content.Size = UDim2.new(1, -20, 1, -10)
        
        local absX = button.AbsolutePosition.X + button.AbsoluteSize.X + 5
        local parentAbs = parent.AbsolutePosition
        if absX + width > parentAbs.X + parent.AbsoluteSize.X then
            absX = button.AbsolutePosition.X - width - 5
        end
        popup.Position = UDim2.new(0, absX, 0, button.AbsolutePosition.Y + button.AbsoluteSize.Y/2 - height/2)
    end
    
    local function showPopup()
        if hideTimer then
            task.cancel(hideTimer)
            hideTimer = nil
        end
        isVisible = true
        
        popup.Visible = true
        popup.Size = UDim2.new(0, 0, 0, 0)
        popup.BackgroundTransparency = 1
        
        updatePopup()
        
        TweenService:Create(popup, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0.035
        }):Play()
        TweenService:Create(stroke, TweenInfo.new(0.15), {
            Transparency = 0.65
        }):Play()
        TweenService:Create(content, TweenInfo.new(0.15), {
            TextTransparency = 0.3
        }):Play()
    end
    
    local function hidePopup()
        if hideTimer then
            task.cancel(hideTimer)
            hideTimer = nil
        end
        
        TweenService:Create(popup, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 1
        }):Play()
        TweenService:Create(stroke, TweenInfo.new(0.1), {
            Transparency = 1
        }):Play()
        TweenService:Create(content, TweenInfo.new(0.1), {
            TextTransparency = 1
        }):Play()
        
        task.wait(0.1)
        popup.Visible = false
        isVisible = false
    end
    
    local function scheduleHide()
        if hideTimer then
            task.cancel(hideTimer)
            hideTimer = nil
        end
        hideTimer = task.delay(0.5, function()
            if not isVisible then return end
            local pos = UIS:GetMouseLocation()
            local popupAbs = popup.AbsolutePosition
            local popupSize = popup.AbsoluteSize
            local btnAbs = button.AbsolutePosition
            local btnSize = button.AbsoluteSize
            
            local onPopup = pos.X >= popupAbs.X and pos.X <= popupAbs.X + popupSize.X and
                           pos.Y >= popupAbs.Y and pos.Y <= popupAbs.Y + popupSize.Y
            local onButton = pos.X >= btnAbs.X and pos.X <= btnAbs.X + btnSize.X and
                             pos.Y >= btnAbs.Y and pos.Y <= btnAbs.Y + btnSize.Y
            
            if not onPopup and not onButton then
                hidePopup()
            else
                scheduleHide()
            end
        end)
    end
    
    button.MouseEnter:Connect(function()
        if text and text ~= "" then
            showPopup()
        end
    end)
    
    button.MouseLeave:Connect(function()
        scheduleHide()
    end)
    
    popup.MouseEnter:Connect(function()
        if hideTimer then
            task.cancel(hideTimer)
            hideTimer = nil
        end
    end)
    
    popup.MouseLeave:Connect(function()
        scheduleHide()
    end)
    
    UIS.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if isVisible then
                local pos = input.Position
                local popupAbs = popup.AbsolutePosition
                local popupSize = popup.AbsoluteSize
                local btnAbs = button.AbsolutePosition
                local btnSize = button.AbsoluteSize
                
                local onPopup = pos.X >= popupAbs.X and pos.X <= popupAbs.X + popupSize.X and
                               pos.Y >= popupAbs.Y and pos.Y <= popupAbs.Y + popupSize.Y
                local onButton = pos.X >= btnAbs.X and pos.X <= btnAbs.X + btnSize.X and
                                 pos.Y >= btnAbs.Y and pos.Y <= btnAbs.Y + btnSize.Y
                
                if not onPopup and not onButton then
                    hidePopup()
                end
            end
        end
    end)
    
    button.Destroying:Connect(function()
        popup:Destroy()
    end)
    
    return {
        Show = showPopup,
        Hide = hidePopup,
        Update = updatePopup,
        SetText = function(newText)
            content.Text = newText
            updatePopup()
        end,
        _isVisible = isVisible,
    }
end

