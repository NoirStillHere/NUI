-- EFFECT: GRADIENT XOAY TRÒN (Giống ví dụ DesyncZEN)
-- ============================================================

local function CreateRotatingGradient(stroke, colors, speed)
    if not stroke then return nil end
    
    local gradient = Instance.new("UIGradient", stroke)
    
    -- Tạo color sequence với nhiều màu
    local colorKeypoints = {}
    for i, color in ipairs(colors) do
        local position = (i - 1) / (#colors - 1)
        table.insert(colorKeypoints, ColorSequenceKeypoint.new(position, color))
    end
    
    gradient.Color = ColorSequence.new(colorKeypoints)
    gradient.Transparency = NumberSequence.new(0)
    gradient.Rotation = 0
    
    speed = speed or 120
    
    -- Xoay gradient liên tục
    local connection
    connection = RunService.RenderStepped:Connect(function(dt)
        if not stroke or not stroke.Parent then
            connection:Disconnect()
            return
        end
        gradient.Rotation = (gradient.Rotation + dt * speed) % 360
    end)
    
    table.insert(NoirUI.Connections, connection)
    return gradient, connection
end

