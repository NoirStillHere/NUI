-- THÊM CONFIG DROPDOWN VÀO HEADER (Từ Neverlose)
-- ============================================
local function AddConfigDropdown()
    local MainFrame = Window.Root:FindFirstChildOfClass("Frame")
    if not MainFrame then return end

    local Header = MainFrame:FindFirstChildWhichIsA("Frame")
    if not Header then return end

    -- Config folder
    local ConfigFolder = "NoirConfigs"
    if not isfolder(ConfigFolder) then
        makefolder(ConfigFolder)
    end

    -- Config button
    local ConfigBtn = Instance.new("Frame")
    ConfigBtn.Size = UDim2.new(0, 120, 0, 28)
    ConfigBtn.Position = UDim2.new(0, 10, 0.5, -14)
    ConfigBtn.BackgroundColor3 = NoirColors.Surface
    ConfigBtn.BackgroundTransparency = 0.5
    ConfigBtn.ZIndex = 10
    ConfigBtn.Parent = Header
    Instance.new("UICorner", ConfigBtn).CornerRadius = UDim.new(0, 6)
    
    local Stroke = Instance.new("UIStroke")
    Stroke.Color = NoirColors.Border
    Stroke.Thickness = 1
    Stroke.Transparency = 0.5
    Stroke.Parent = ConfigBtn

    -- Icon
    local ConfigIcon = Instance.new("ImageLabel")
    ConfigIcon.Size = UDim2.new(0, 16, 0, 16)
    ConfigIcon.Position = UDim2.new(0, 8, 0.5, -8)
    ConfigIcon.BackgroundTransparency = 1
    ConfigIcon.Image = LucideIcons['folder']
    ConfigIcon.ImageColor3 = NoirColors.TextSecondary
    ConfigIcon.Parent = ConfigBtn

    -- Label
    local ConfigLabel = Instance.new("TextLabel")
    ConfigLabel.Size = UDim2.new(1, -50, 1, 0)
    ConfigLabel.Position = UDim2.new(0, 30, 0, 0)
    ConfigLabel.BackgroundTransparency = 1
    ConfigLabel.Text = "Default"
    ConfigLabel.TextColor3 = NoirColors.Text
    ConfigLabel.TextTransparency = 0.3
    ConfigLabel.Font = Enum.Font.Gotham
    ConfigLabel.TextSize = 11
    ConfigLabel.TextXAlignment = Enum.TextXAlignment.Left
    ConfigLabel.Parent = ConfigBtn

    -- Dropdown arrow
    local Arrow = Instance.new("ImageLabel")
    Arrow.Size = UDim2.new(0, 16, 0, 16)
    Arrow.Position = UDim2.new(1, -20, 0.5, -8)
    Arrow.BackgroundTransparency = 1
    Arrow.Image = LucideIcons['chevron-down'] or "rbxassetid://109535175596957"
    Arrow.ImageColor3 = NoirColors.TextSecondary
    Arrow.Parent = ConfigBtn

    -- Dropdown menu
    local Dropdown = Instance.new("Frame")
    Dropdown.Size = UDim2.new(0, 180, 0, 100)
    Dropdown.Position = UDim2.new(0, 0, 0, 35)
    Dropdown.BackgroundColor3 = NoirColors.Surface
    Dropdown.BackgroundTransparency = 1
    Dropdown.ZIndex = 15
    Dropdown.ClipsDescendants = true
    Dropdown.Visible = false
    Dropdown.Parent = ConfigBtn
    Instance.new("UICorner", Dropdown).CornerRadius = UDim.new(0, 6)

    local DropdownStroke = Instance.new("UIStroke")
    DropdownStroke.Color = NoirColors.Border
    DropdownStroke.Thickness = 1
    DropdownStroke.Transparency = 1
    DropdownStroke.Parent = Dropdown

    local List = Instance.new("ScrollingFrame")
    List.Size = UDim2.new(1, 0, 1, 0)
    List.BackgroundTransparency = 1
    List.ScrollBarThickness = 2
    List.Parent = Dropdown

    local Layout = Instance.new("UIListLayout")
    Layout.Padding = UDim.new(0, 2)
    Layout.Parent = List

    -- Hàm refresh config list
    local function RefreshConfigs()
        for _, child in pairs(List:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end

        local configs = listfiles(ConfigFolder)
        for _, path in pairs(configs) do
            local name = string.match(path, "([^/\\]+)$") or path
            local item = Instance.new("Frame")
            item.Size = UDim2.new(1, -10, 0, 25)
            item.BackgroundTransparency = 1
            item.Parent = List

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, -5, 1, 0)
            label.Position = UDim2.new(0, 5, 0, 0)
            label.BackgroundTransparency = 1
            label.Text = name
            label.TextColor3 = NoirColors.Text
            label.TextTransparency = 0.3
            label.Font = Enum.Font.Gotham
            label.TextSize = 11
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = item

            -- Hover
            item.MouseEnter:Connect(function()
                label.TextTransparency = 0
                item.BackgroundTransparency = 0.3
            end)
            item.MouseLeave:Connect(function()
                label.TextTransparency = 0.3
                item.BackgroundTransparency = 1
            end)

            -- Click load
            item.MouseButton1Click:Connect(function()
                ConfigLabel.Text = name
                Dropdown.Visible = false
                Dropdown.BackgroundTransparency = 1
                DropdownStroke.Transparency = 1
                -- Load config
                local data = readfile(path)
                if data then
                    -- Parse và load config
                    local success, decoded = pcall(function()
                        return game:GetService("HttpService"):JSONDecode(data)
                    end)
                    if success and decoded then
                        for flag, value in pairs(decoded) do
                            if CK.Flags[flag] and CK.Flags[flag].SetValue then
                                CK.Flags[flag]:SetValue(value)
                            end
                        end
                        PlaySound("Success")
                    end
                end
            end)

            -- Delete
            local del = Instance.new("ImageLabel")
            del.Size = UDim2.new(0, 14, 0, 14)
            del.Position = UDim2.new(1, -18, 0.5, -7)
            del.BackgroundTransparency = 1
            del.Image = LucideIcons['x']
            del.ImageColor3 = NoirColors.Error
            del.ImageTransparency = 0.5
            del.Parent = item

            del.MouseEnter:Connect(function()
                del.ImageTransparency = 0
            end)
            del.MouseLeave:Connect(function()
                del.ImageTransparency = 0.5
            end)

            del.MouseButton1Click:Connect(function()
                delfile(path)
                RefreshConfigs()
                PlaySound("Click")
            end)
        end
    end

    -- Toggle dropdown
    ConfigBtn.MouseButton1Click:Connect(function()
        Dropdown.Visible = not Dropdown.Visible
        if Dropdown.Visible then
            Dropdown.BackgroundTransparency = 0.95
            DropdownStroke.Transparency = 0.5
            Arrow.Rotation = 180
            RefreshConfigs()
        else
            Dropdown.BackgroundTransparency = 1
            DropdownStroke.Transparency = 1
            Arrow.Rotation = 0
        end
    end)

    -- Save config
    local function SaveConfig(name)
        if not name or name == "" then return end
        local data = {}
        for flag, obj in pairs(CK.Flags) do
            if obj.GetValue then
                data[flag] = obj:GetValue()
            end
        end
        local json = game:GetService("HttpService"):JSONEncode(data)
        writefile(ConfigFolder .. "/" .. name, json)
        ConfigLabel.Text = name
        PlaySound("Success")
        RefreshConfigs()
    end

    -- Tạo config mới
    local NewConfig = Instance.new("Frame")
    NewConfig.Size = UDim2.new(0, 120, 0, 28)
    NewConfig.Position = UDim2.new(0, 140, 0.5, -14)
    NewConfig.BackgroundColor3 = NoirColors.Accent
    NewConfig.BackgroundTransparency = 0.2
    NewConfig.ZIndex = 10
    NewConfig.Parent = Header
    Instance.new("UICorner", NewConfig).CornerRadius = UDim.new(0, 6)

    local NewIcon = Instance.new("ImageLabel")
    NewIcon.Size = UDim2.new(0, 16, 0, 16)
    NewIcon.Position = UDim2.new(0.5, -8, 0.5, -8)
    NewIcon.BackgroundTransparency = 1
    NewIcon.Image = LucideIcons['plus']
    NewIcon.ImageColor3 = NoirColors.Text
    NewIcon.Parent = NewConfig

    local NewLabel = Instance.new("TextLabel")
    NewLabel.Size = UDim2.new(1, 0, 1, 0)
    NewLabel.BackgroundTransparency = 1
    NewLabel.Text = "NEW"
    NewLabel.TextColor3 = NoirColors.Text
    NewLabel.TextTransparency = 0.5
    NewLabel.Font = Enum.Font.GothamBold
    NewLabel.TextSize = 10
    NewLabel.TextXAlignment = Enum.TextXAlignment.Center
    NewLabel.Visible = false
    NewLabel.Parent = NewConfig

    -- Hover
    NewConfig.MouseEnter:Connect(function()
        NewConfig.BackgroundTransparency = 0
    end)
    NewConfig.MouseLeave:Connect(function()
        NewConfig.BackgroundTransparency = 0.2
    end)

    -- Click tạo config mới
    NewConfig.MouseButton1Click:Connect(function()
        local name = "Config_" .. os.time()
        SaveConfig(name)
    end)

    return { Save = SaveConfig }
end

AddConfigDropdown()

