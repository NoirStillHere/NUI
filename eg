            Instance.new("UICorner", t).CornerRadius = UDim.new(0, CORNER_RADIUS)
            t.LayoutOrder = GetO()
            t.AutoButtonColor = false
            table.insert(Tab.Elements, t)
            
            local bx = Instance.new("Frame", t)
            bx.Size = UDim2.new(0, 30, 0, 16)
            bx.Position = UDim2.new(1, -40, 0.5, -8)
            bx.BackgroundColor3 = s and ACCENT or Color3.fromRGB(200, 200, 200)
            bx.BackgroundTransparency = 0.3
            Instance.new("UICorner", bx).CornerRadius = UDim.new(1, 0)
            
            t.MouseButton1Click:Connect(function()
                PlaySound("Element")
                CreateClickScaleEffect(t)
                s = not s
                t.TextColor3 = s and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(150, 150, 150)
                TweenService:Create(bx, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    BackgroundColor3 = s and ACCENT or Color3.fromRGB(200, 200, 200)
                }):Play()
                if opt.Callback then opt.Callback(s) end
            end)
            return t
        end
        
        return Tab
    end

    return Window
end

return NoirUI
