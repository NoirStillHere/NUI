local BlurManager = {
    Enabled = false,
    Intensity = 1,
    Target = nil,
    BlurPart = nil,
    DepthOfField = nil,
    Connections = {},
}

function BlurManager:Create(parent)
    if self.Enabled then self:Destroy() end
    
    self.Target = parent
    
    local part = Instance.new("Part")
    part.Size = Vector3.new(0.01, 0.01, 0.01)
    part.Material = Enum.Material.Glass
    part.Transparency = 1
    part.Reflectance = 1
    part.CastShadow = false
    part.Anchored = true
    part.CanCollide = false
    part.CanQuery = false
    part.Name = "NoirUI_BlurPart"
    part.Parent = Workspace.CurrentCamera
    
    local dof = Instance.new("DepthOfFieldEffect")
    dof.Enabled = true
    dof.FarIntensity = 0
    dof.FocusDistance = 0
    dof.InFocusRadius = 1000
    dof.NearIntensity = self.Intensity
    dof.Name = "NoirUI_DepthOfField"
    dof.Parent = Lighting
    
    self.BlurPart = part
    self.DepthOfField = dof
    self.Enabled = true
    
    local function UpdateBlur()
        if not self.Enabled or not self.Target then return end
        
        local camera = Workspace.CurrentCamera
        if not camera then return end
        
        if not self.Target.Parent then
            self:Destroy()
            return
        end
        
        local corner0 = self.Target.AbsolutePosition
        local corner1 = corner0 + self.Target.AbsoluteSize
        
        local ray0 = camera:ScreenPointToRay(corner0.X, corner0.Y, 1)
        local ray1 = camera:ScreenPointToRay(corner1.X, corner1.Y, 1)
        
        local planeOrigin = camera.CFrame.Position + camera.CFrame.LookVector * (0.05 - camera.NearPlaneZ)
        local planeNormal = camera.CFrame.LookVector
        
        local function GetIntersection(rayOrigin, rayDirection)
            local t = -(planeNormal:Dot(rayOrigin - planeOrigin)) / planeNormal:Dot(rayDirection)
            return rayOrigin + t * rayDirection
        end
        
        local pos0 = GetIntersection(ray0.Origin, ray0.Direction)
        local pos1 = GetIntersection(ray1.Origin, ray1.Direction)
        
        local cf = camera.CFrame
        pos0 = cf:PointToObjectSpace(pos0)
        pos1 = cf:PointToObjectSpace(pos1)
        
        local size = pos1 - pos0
        local center = (pos0 + pos1) / 2
        
        self.BlurPart.CFrame = cf
        
        local mesh = self.BlurPart:FindFirstChild("BlockMesh") or Instance.new("BlockMesh")
        mesh.Parent = self.BlurPart
        mesh.Offset = center
        mesh.Scale = size / 0.0101
    end
    
    local conn1 = camera:GetPropertyChangedSignal("CFrame"):Connect(UpdateBlur)
    local conn2 = RunService.RenderStepped:Connect(UpdateBlur)
    local conn3 = UIS.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            UpdateBlur()
        end
    end)
    
    self.Connections = {conn1, conn2, conn3}
    UpdateBlur()
    
    return self
end

function BlurManager:SetIntensity(intensity)
    self.Intensity = math.clamp(intensity, 0, 1)
    if self.DepthOfField then
        self.DepthOfField.NearIntensity = self.Intensity
    end
end

function BlurManager:Toggle()
    self.Enabled = not self.Enabled
    if self.DepthOfField then
        self.DepthOfField.Enabled = self.Enabled
    end
    if self.BlurPart then
        self.BlurPart.Transparency = self.Enabled and 1 or 0
    end
end

function BlurManager:Destroy()
    self.Enabled = false
    
    if self.DepthOfField then
        self.DepthOfField:Destroy()
        self.DepthOfField = nil
    end
    
    if self.BlurPart then
        self.BlurPart:Destroy()
        self.BlurPart = nil
    end
    
    for _, conn in ipairs(self.Connections) do
        conn:Disconnect()
    end
    self.Connections = {}
end

-- ==========================================================
-- CONFIG MANAGER
-- ==========================================================
function NoirUI:CreateConfigManager(settings)
    settings = settings or {}
    settings.Directory = settings.Directory or "NoirUI_Configs"
    settings.EnableNotifications = settings.EnableNotifications or true
    
    if not isfolder(settings.Directory) then
        makefolder(settings.Directory)
    end
    
    local ConfigManager = {
        Directory = settings.Directory,
        EnableNotifications = settings.EnableNotifications,
    }
    
    function ConfigManager:GetAllFlags()
        local flags = {}
        for name, element in pairs(NoirUI.Flags or {}) do
            if element and element.GetValue then
                local value = element:GetValue()
                flags[name] = {
                    Type = element.Type or "Normal",
                    Value = value
                }
            end
        end
        return flags
    end
    
    function ConfigManager:SaveConfig(configName, author)
        configName = configName or "config_" .. os.time()
        author = author or LocalPlayer.Name
        
        local flags = self:GetAllFlags()
        flags["__INFORMATION"] = {
            Type = "Information",
            Author = author,
            Name = configName,
            CreatedDate = os.date("%d/%m/%Y %H:%M:%S"),
            Version = _version
        }
        
        local path = self.Directory .. "/" .. configName
        writefile(path, HttpService:JSONEncode(flags))
        
        if self.EnableNotifications then
            NoirUI:Notify("Config Manager", "Đã lưu config: " .. configName, "save", "Success", 2)
        end
        
        return true
    end
    
    function ConfigManager:LoadConfig(configName)
        local path = self.Directory .. "/" .. configName
        
        if not isfile(path) then
            if self.EnableNotifications then
                NoirUI:Notify("Config Manager", "Không tìm thấy: " .. configName, "alert-triangle", "Error", 2)
            end
            return false
        end
        
        local json = readfile(path)
        local decoded = HttpService:JSONDecode(json)
        
        for flagName, data in pairs(decoded) do
            if flagName ~= "__INFORMATION" then
                local element = NoirUI.Flags and NoirUI.Flags[flagName]
                if element and element.SetValue then
                    if data.Value ~= nil then
                        element:SetValue(data.Value)
                    end
                end
            end
        end
        
        if self.EnableNotifications then
            NoirUI:Notify("Config Manager", "Đã tải config: " .. configName, "download", "Success", 2)
        end
        
        return true
    end
    
    function ConfigManager:DeleteConfig(configName)
        local path = self.Directory .. "/" .. configName
        
        if isfile(path) then
            delfile(path)
            if self.EnableNotifications then
                NoirUI:Notify("Config Manager", "Đã xóa config: " .. configName, "trash-2", "Element", 2)
            end
            return true
        end
        return false
    end
    
    function ConfigManager:GetConfigs()
        local configs = {}
        local files = listfiles(self.Directory)
        
        for _, file in ipairs(files) do
            local name = file:match("([^/]+)$")
            if name then
                table.insert(configs, name)
            end
        end
        
        return configs
    end
    
    function ConfigManager:GetConfigInfo(configName)
        local path = self.Directory .. "/" .. configName
        
        if not isfile(path) then return nil end
        
        local json = readfile(path)
        local decoded = HttpService:JSONDecode(json)
        return decoded["__INFORMATION"] or nil
    end
    
    function ConfigManager:GetConfigCount()
        return #listfiles(self.Directory)
    end
    
    return ConfigManager
end

