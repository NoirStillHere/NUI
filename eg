-- ============================================
-- BLUR OVERLAY (CÓ CẮT THEO VIỀN - CORNER TÙY CHỈNH)
-- ============================================
local function AddBlurOverlay(parent, blurAmount, customCornerRadius)
    if not parent or not blurAmount or blurAmount <= 0 then return nil end
    local existing = parent:FindFirstChild("BlurWrapper")
    if existing then existing:Destroy() end

    local wrapper = Instance.new("Frame", parent)
    wrapper.Name = "BlurWrapper"
    wrapper.Size = UDim2.new(1, 0, 1, 0)
    wrapper.Position = UDim2.new(0, 0, 0, 0)
    wrapper.BackgroundTransparency = 1
    wrapper.ZIndex = 0
    wrapper.ClipsDescendants = true

    -- Sử dụng customCornerRadius nếu có, không thì lấy từ parent
    local corner = Instance.new("UICorner", wrapper)
    if customCornerRadius then
        corner.CornerRadius = customCornerRadius
    else
        local parentCorner = parent:FindFirstChild("UICorner")
        if parentCorner then
            corner.CornerRadius = parentCorner.CornerRadius
        else
            corner.CornerRadius = UDim.new(0, 12) -- Mặc định
        end
    end

    local blur = Instance.new("Frame", wrapper)
    blur.Name = "BlurOverlay"
    blur.Size = UDim2.new(1, 0, 1, 0)
    blur.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    blur.BackgroundTransparency = 1 - math.clamp(blurAmount, 0, 1)
    blur.ZIndex = 0
    blur.BorderSizePixel = 0

    return wrapper
end

-- Hàm cập nhật bo góc cho blur
local function UpdateBlurCorner(parent, newCornerRadius)
    local wrapper = parent:FindFirstChild("BlurWrapper")
    if wrapper then
        local corner = wrapper:FindFirstChild("UICorner")
        if corner then
            corner.CornerRadius = newCornerRadius
        end
    end
end

