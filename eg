                    NoirUI:_Animation(SelectionFrame, TweenInfo.new(0.1), { BackgroundTransparency = 1 });
                else
                    if math.abs(distance) <= 10 then
                        NoirUI:_Animation(SelectionFrame, TweenInfo.new(0.1), { BackgroundTransparency = 0 });
