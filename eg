        "rbxassetid://10747384394",
        "rbxassetid://10734941499",
        NoirUI.Logo,
    };

    if NoirUI.SecureMode then
        for i, v in next, RequiredAssets do task.wait()
            pcall(function()
                NoirUI:CacheImage(v);
            end);
        end;
