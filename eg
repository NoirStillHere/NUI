            })
            fillGradient.Transparency = NumberSequence.new(0)
            fillGradient.Rotation = 0
            
            local fillRotateConnection
            fillRotateConnection = RunService.RenderStepped:Connect(function(dt)
                if not fill or not fill.Parent then
                    fillRotateConnection:Disconnect()
                    return
                end
                fillGradient.Rotation = (fillGradient.Rotation + dt * accentSpeed * 0.5) % 360
            end)
