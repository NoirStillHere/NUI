        close.Size = UDim2.new(0, 20, 0, 20)
        close.Position = UDim2.new(1, -25, 0.5, -10)
        close.AnchorPoint = Vector2.new(1, 0.5)
        close.BackgroundTransparency = 1
        close.Text = "×"
        close.TextColor3 = Color3.fromRGB(165, 165, 180)
        close.TextSize = 16
        close.Font = Enum.Font.GothamBold
        close.Parent = Toast
        
        close.MouseButton1Click:Connect(function()
            Toasts:Remove(Toast)
        end)
        
        local function updateSize()
            local textSize = TextService:GetTextSize(msg.Text, msg.TextSize, msg.Font, Vector2.new(Toast.AbsoluteSize.X - 50, math.huge))
            local height = math.max(textSize.Y + 20, 50)
            Toast.Size = UDim2.new(1, 0, 0, height)
        end
        
        msg:GetPropertyChangedSignal("Text"):Connect(updateSize)
        task.defer(updateSize)
        
        if duration > 0 then
            task.delay(duration, function()
                Toasts:Remove(Toast)
            end)
        end
        
        return Toast
    end
    
    function Toasts:Remove(toast)
        if not toast or not toast.Parent then return end
        
        TweenService:Create(toast, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 0)
        }):Play()
        
        task.delay(0.3, function()
            toast:Destroy()
        end)
    end
    
    function Toasts:Clear()
        for _, child in ipairs(Container:GetChildren()) do
            if child:IsA("Frame") then
                self:Remove(child)
            end
        end
    end
    
    function Toasts:Destroy()
        self:Clear()
        Container:Destroy()
    end
    
    return Toasts
end

