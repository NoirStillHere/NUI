            content.Size = UDim2.new(1, 0, 0, 0)
            content.Position = UDim2.new(0, 0, 0, 28)
            content.BackgroundTransparency = 1
            content.ZIndex = 4
            content.Name = "ExtractContent"
            content.ClipsDescendants = true
            content.AutomaticSize = Enum.AutomaticSize.Y
            
            local contentLayout = Instance.new("UIListLayout", content)
            contentLayout.Padding = UDim.new(0, 4)
            contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
            
            local padding = Instance.new("Frame", content)
            padding.Size = UDim2.new(1, 0, 0, 4)
            padding.BackgroundTransparency = 1
            padding.LayoutOrder = -1
            
            local isOpen = false
            
            header.MouseButton1Click:Connect(function()
                PlaySound("Element")
                CreateClickScaleEffect(header)
                isOpen = not isOpen
                
                TweenService:Create(arrow, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Rotation = isOpen and 180 or 0
                }):Play()
                
                if isOpen then
                    content.Visible = true
                    local targetHeight = contentLayout.AbsoluteContentSize.Y + 8
                    content.Size = UDim2.new(1, 0, 0, 0)
                    TweenService:Create(content, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                        Size = UDim2.new(1, 0, 0, targetHeight)
                    }):Play()
                    container.Size = UDim2.new(0.95, 0, 0, 28 + targetHeight)
                else
                    TweenService:Create(content, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                        Size = UDim2.new(1, 0, 0, 0)
                    }):Play()
                    task.wait(0.3)
                    content.Visible = false
                    container.Size = UDim2.new(0.95, 0, 0, 28)
                end
            end)
            
            function extractTab:CreateButton(opt)
                local b = Instance.new("TextButton", content)
                b.Size = UDim2.new(1, -10, 0, 30)
                b.Position = UDim2.new(0, 5, 0, 0)
                b.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
                b.BackgroundTransparency = 0.6
                b.Text = opt.Name
                b.TextColor3 = Color3.fromRGB(255, 255, 255)
                b.Font = "GothamMedium"
                b.TextSize = 12
                b.ZIndex = 5
                b.TextXAlignment = "Left"
                b.Text = "  " .. opt.Name
                Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
                b.AutoButtonColor = false
                
                b.MouseButton1Click:Connect(function()
                    PlaySound("Element")
                    CreateClickScaleEffect(b)
                    if opt.Callback then opt.Callback() end
                end)
                return b
            end
            
            function extractTab:CreateToggle(opt)
                local s = opt.Default or false
                local t = Instance.new("TextButton", content)
                t.Size = UDim2.new(1, -10, 0, 30)
                t.Position = UDim2.new(0, 5, 0, 0)
                t.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
                t.BackgroundTransparency = 0.6
                t.Text = "  " .. opt.Name
                t.TextColor3 = s and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 180)
                t.TextXAlignment = "Left"
                t.TextSize = 12
                t.Font = "GothamMedium"
                t.ZIndex = 5
                Instance.new("UICorner", t).CornerRadius = UDim.new(0, 6)
                t.AutoButtonColor = false
                
                local bx = Instance.new("Frame", t)
                bx.Size = UDim2.new(0, 24, 0, 14)
                bx.Position = UDim2.new(1, -30, 0.5, -7)
                bx.BackgroundColor3 = s and ACCENT or Color3.fromRGB(40, 40, 40)
                bx.BackgroundTransparency = 0.3
                bx.ZIndex = 6
                Instance.new("UICorner", bx).CornerRadius = UDim.new(1, 0)
                
                t.MouseButton1Click:Connect(function()
                    PlaySound("Element")
                    CreateClickScaleEffect(t)
                    s = not s
                    t.TextColor3 = s and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 180)
                    TweenService:Create(bx, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                        BackgroundColor3 = s and ACCENT or Color3.fromRGB(40, 40, 40)
                    }):Play()
                    if opt.Callback then opt.Callback(s) end
                end)
                return t
            end
            
            function extractTab:CreateSlider(opt)
                -- Code slider tương tự nhưng parent = content
            end
            
            return extractTab
        end
        
        -- ============================================
        -- 27. LƯU TAB
        -- ============================================
        table.insert(windowTabs, Tab)
        Tab._button = B
        
        return Tab
    end
    
    -- ============================================
    -- 28. LƯU WINDOW REF
    -- ============================================
    windowRef._Main = Main
    windowRef._Header = Header
    windowRef._Title = Title
    windowRef._Description = Description
    windowRef._Side = Side
    windowRef._Cont = Cont
    windowRef._FloatBtn = TBtn
    windowRef._LoadingBar = LoadingBar
    windowRef._MainStroke = MainStroke
    windowRef._allTabButtons = allTabButtons
    windowRef._tabs = windowTabs
    windowRef._useAutoContrast = useAutoContrast
    windowRef._settings = settings
    windowRef._screen = ScreenGui
    windowRef._userSettingsPanel = nil
    
    table.insert(NoirUI._windows, windowRef)
    
    task.wait()
    updateSidebarCanvas()
    
    return windowRef
end

return NoirUI
