local NoirUI = {}

-- Service
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- Hàm tạo tween
local function createTween(obj, props, time, style, direction)
    return TweenService:Create(obj, TweenInfo.new(time or 0.3, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out), props)
end

-- Hàm tạo UI cơ bản
local function createInstance(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        inst[k] = v
    end
    return inst
end

-- ============================================================
-- 1. Tạo cửa sổ chính (Có Drag & Clamp + Responsive)
-- ============================================================
function NoirUI.CreateWindow(config)
    config = config or {}
    local title = config.Title or "NoirUI"
    local theme = config.Theme or {
        MainBg = Color3.fromRGB(10, 10, 18),
        SidebarBg = Color3.fromRGB(15, 15, 25),
        Accent = Color3.fromRGB(120, 60, 255),
        Text = Color3.fromRGB(255, 255, 255),
        TextMuted = Color3.fromRGB(180, 180, 200),
        CardBg = Color3.fromRGB(20, 20, 35)
    }
    
    -- 🔥 Kích thước cơ bản đã đổi thành 350x700 (dạng mobile)
    local baseWidth = 350
    local baseHeight = 700

    -- ScreenGui
    local gui = createInstance("ScreenGui", {
        Name = "NoirUI_" .. title,
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        Parent = LocalPlayer.PlayerGui
    })

    -- Float Button (kích thước nhỏ lại cho cân đối)
    local floatBtn = createInstance("TextButton", {
        Size = UDim2.new(0, 50, 0, 50),
        Position = UDim2.new(0.02, 0, 0.5, -25),
        BackgroundColor3 = theme.Accent,
        Text = "N",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 24,
        Font = Enum.Font.GothamBold,
        Parent = gui
    })
    createInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = floatBtn})

    -- Main Window
    local main = createInstance("Frame", {
        Size = UDim2.new(0, baseWidth, 0, baseHeight),
        Position = UDim2.new(0.5, -baseWidth/2, 0.5, -baseHeight/2),
        BackgroundColor3 = theme.MainBg,
        Visible = false,
        Parent = gui
    })
    createInstance("UICorner", {CornerRadius = UDim.new(0, 16), Parent = main})

    -- Responsive: Tự co giãn theo màn hình
    local aspectRatio = createInstance("UIAspectRatioConstraint", {
        AspectRatio = baseWidth / baseHeight, -- 350/700 = 0.5
        Parent = main
    })
    
    -- Giới hạn kích thước tối đa (không quá to, không quá nhỏ)
    local maxSize = createInstance("UISizeConstraint", {
        MaxSize = Vector2.new(baseWidth * 1.2, baseHeight * 1.2),
        MinSize = Vector2.new(baseWidth * 0.6, baseHeight * 0.6),
        Parent = main
    })

    -- Sidebar (hẹp hơn cho vừa tỉ lệ)
    local sidebar = createInstance("Frame", {
        Size = UDim2.new(0, 60, 1, 0), -- 60px thay vì 80px
        BackgroundColor3 = theme.SidebarBg,
        Parent = main
    })
    createInstance("UICorner", {CornerRadius = UDim.new(0, 16), Parent = sidebar})

    -- Content area (rộng hơn để chứa nội dung)
    local content = createInstance("Frame", {
        Size = UDim2.new(1, -80, 1, -20), -- Trừ 80 cho sidebar + padding
        Position = UDim2.new(0, 80, 0, 10),
        BackgroundTransparency = 1,
        Parent = main
    })

    -- Title (nhỏ lại)
    createInstance("TextLabel", {
        Size = UDim2.new(1, 0, 0, 35),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = theme.Text,
        TextSize = 22,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = content
    })

    -- Close button (góc trên phải của main)
    local closeBtn = createInstance("TextButton", {
        Size = UDim2.new(0, 25, 0, 25),
        Position = UDim2.new(1, -35, 0, 8),
        BackgroundTransparency = 1,
        Text = "✕",
        TextColor3 = Color3.fromRGB(255, 80, 80),
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        Parent = main
    })

    -- ============================================================
    -- DRAG & DROP THÔNG MINH (CÓ GIỚI HẠN)
    -- ============================================================
    local dragging = false
    local dragInput, mousePos, framePos

    main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            mousePos = input.Position
            framePos = main.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    main.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - mousePos
            local newX = framePos.X.Offset + delta.X
            local newY = framePos.Y.Offset + delta.Y
            
            local screenSize = workspace.CurrentCamera.ViewportSize
            local frameSize = main.AbsoluteSize
            
            newX = math.clamp(newX, 0, screenSize.X - frameSize.X)
            newY = math.clamp(newY, 0, screenSize.Y - frameSize.Y)
            
            main.Position = UDim2.new(0, newX, 0, newY)
        end
    end)

    -- Animation toggle
    local isOpen = false
    local openTweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local closeTweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

    local function toggleUI()
        isOpen = not isOpen
        if isOpen then
            main.Visible = true
            if main.Position.X.Offset < 0 or main.Position.X.Offset > workspace.CurrentCamera.ViewportSize.X then
                main.Position = UDim2.new(0.5, -baseWidth/2, 0.5, -baseHeight/2)
            end
            createTween(main, {BackgroundTransparency = 0}, 0.4):Play()
        else
            local t = createTween(main, {BackgroundTransparency = 1}, 0.3)
            t:Play()
            t.Completed:Connect(function()
                main.Visible = false
            end)
        end
    end

    floatBtn.MouseButton1Click:Connect(toggleUI)
    closeBtn.MouseButton1Click:Connect(toggleUI)

    -- Trả về API
    return {
        Gui = gui,
        Main = main,
        Sidebar = sidebar,
        Content = content,
        Theme = theme,
        Toggle = toggleUI,
        Close = toggleUI,
        _CreateElement = createInstance
    }
end

-- ============================================================
-- 2. Tạo Sidebar Icon (icon nhỏ hơn cho vừa sidebar 60px)
-- ============================================================
function NoirUI.CreateSidebarIcon(window, config)
    local sidebar = window.Sidebar
    local theme = window.Theme
    local icon = config.Icon or "⌂"
    local position = config.Position or 60
    local isActive = config.Active or false
    local callback = config.Callback or function() end

    local btn = window._CreateElement("TextButton", {
        Size = UDim2.new(0, 32, 0, 32), -- Nhỏ hơn
        Position = UDim2.new(0.5, -16, 0, position),
        BackgroundTransparency = isActive and 0.2 or 1,
        BackgroundColor3 = theme.Accent,
        Text = icon,
        TextColor3 = isActive and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 180),
        TextSize = 16, -- Chữ nhỏ hơn
        Font = Enum.Font.GothamBold,
        Parent = sidebar
    })
    window._CreateElement("UICorner", {CornerRadius = UDim.new(1, 0), Parent = btn})

    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- ============================================================
-- 3. Tạo Card (Dashboard) - Nhỏ gọn hơn
-- ============================================================
function NoirUI.CreateCard(window, config)
    local content = window.Content
    local theme = window.Theme
    local title = config.Title or "Card"
    local value = config.Value or "0"
    local position = config.Position or UDim2.new(0, 0, 0, 50)

    -- Card nhỏ hơn cho vừa 350px
    local card = window._CreateElement("Frame", {
        Size = UDim2.new(0, 160, 0, 90),
        Position = position,
        BackgroundColor3 = theme.CardBg,
        Parent = content
    })
    window._CreateElement("UICorner", {CornerRadius = UDim.new(0, 10), Parent = card})

    window._CreateElement("TextLabel", {
        Size = UDim2.new(1, 0, 0, 20),
        Position = UDim2.new(0, 10, 0, 8),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = theme.TextMuted,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = card
    })

    window._CreateElement("TextLabel", {
        Size = UDim2.new(1, 0, 0, 30),
        Position = UDim2.new(0, 10, 0, 30),
        BackgroundTransparency = 1,
        Text = value,
        TextColor3 = theme.Text,
        TextSize = 24,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = card
    })

    return card
end

return NoirUI
